---
import Layout from "../../../src/layouts/Layout.astro";

const title = "Status";
const description = "Live status of all Arcbase services.";

interface ServiceStatus {
	name: string;
	status: string;
	lastChecked: string | number | Date;
	details?: string;
}

// Astro server-side data fetching
let statuses: ServiceStatus[] = [];
try {
    // HTTP Actions in Convex are exposed on the SITE URL, not the Cloud URL
	const apiUrl = import.meta.env.PUBLIC_CONVEX_SITE_URL || import.meta.env.PUBLIC_CONVEX_URL;
	if (apiUrl) {
		const res = await fetch(`${apiUrl}/api/status/getServiceStatuses`);
		if (res.ok) {
			statuses = await res.json();
		}
	}
} catch (e) {
	// Fallback: no data
}
---

<Layout title={title} description={description} activePage="status">
	<main style="max-width: 700px; margin: 0 auto; padding: 2rem 1rem;">
		<h1 style="margin-bottom: 1.5rem;">Arcbase Service Status</h1>
		{statuses.length === 0 ? (
			<p>No status data available.</p>
		) : (
			<table style="width:100%; border-collapse:collapse; background:var(--surface); box-shadow:var(--shadow-sm); border-radius:var(--radius-md); overflow:hidden;">
				<thead>
					<tr style="background:var(--bg-secondary);">
						<th style="text-align:left; padding:0.75rem;">Service</th>
						<th style="text-align:left; padding:0.75rem;">Status</th>
						<th style="text-align:left; padding:0.75rem;">Last Checked</th>
						<th style="text-align:left; padding:0.75rem;">Details</th>
					</tr>
				</thead>
				<tbody>
					{statuses.map((s) => (
						<tr style="border-top:1px solid var(--border);">
							<td style="padding:0.75rem; font-weight:500;">{s.name}</td>
							<td style="padding:0.75rem; color:var(--accent);">
								{s.status === "operational" && <span style="color:var(--success);">Operational</span>}
								{s.status === "degraded" && <span style="color:orange;">Degraded</span>}
								{s.status === "down" && <span style="color:red;">Down</span>}
							</td>
							<td style="padding:0.75rem;">{new Date(s.lastChecked).toLocaleString()}</td>
							<td style="padding:0.75rem;">{s.details || "-"}</td>
						</tr>
					))}
				</tbody>
			</table>
		)}
	</main>
</Layout>
