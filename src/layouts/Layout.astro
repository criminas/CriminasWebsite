---
import "../styles/global.css";
import AuthButton from "../components/AuthButton.astro";

export interface Props {
    title: string;
    description: string;
    canonicalUrl?: string;
    ogImage?: string;
    ogType?: string;
    keywords?: string;
    author?: string;
    activePage?: string;
    noIndex?: boolean;
}

const {
    title,
    description,
    canonicalUrl = `https://arcbase.one${Astro.url.pathname}`,
    ogImage = "/logo.png",
    ogType = "website",
    keywords = "open source, linux, software, community, arcbase, developer tools",
    author = "arcbase",
    activePage = "",
    noIndex = false,
} = Astro.props;

const siteTitle = title.includes("arcbase") ? title : `${title} — arcbase`;
const siteUrl = "https://arcbase.one";
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/png" href="/logo.png" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <link rel="preload" href="/logo.png" as="image" />
        <meta name="generator" content={Astro.generator} />

        <title>{siteTitle}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content={keywords} />
        <meta name="author" content={author} />
        <link rel="canonical" href={canonicalUrl} />
        {noIndex && <meta name="robots" content="noindex, nofollow" />}

        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:title" content={siteTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={`${siteUrl}${ogImage}`} />
        <meta property="og:site_name" content="arcbase" />
        <meta property="og:locale" content="en_US" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={siteTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

        <meta name="theme-color" content="#ffffff" />
        <meta name="apple-mobile-web-app-title" content="arcbase" />
        <link rel="apple-touch-icon" href="/logo.png" />

        <script is:inline>
            const theme = localStorage.getItem("theme") || "light";
            document.documentElement.setAttribute("data-theme", theme);
        </script>

        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            rel="stylesheet"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
        />
        <link
            href="https://fonts.googleapis.com/css2?family=Google+Sans:ital,opsz,wght@0,17..18,400..700;1,17..18,400..700&family=Roboto:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />

        <script
            type="application/ld+json"
            set:html={JSON.stringify({
                "@context": "https://schema.org",
                "@type": "Organization",
                name: "arcbase",
                url: siteUrl,
                logo: `${siteUrl}/logo.png`,
                description:
                    "Empowering everyone to change their world, by bringing open source software to the masses.",
                sameAs: ["https://github.com/arcbasehq"],
                contactPoint: {
                    "@type": "ContactPoint",
                    email: "arcbase@tuta.io",
                    contactType: "customer support",
                },
            })}
        />
        <script>
            import { supabase } from "../lib/supabase";
        </script>

        <script>
            import { datadogRum } from "@datadog/browser-rum";

            const applicationId = import.meta.env.PUBLIC_DATADOG_APPLICATION_ID;
            const clientToken = import.meta.env.PUBLIC_DATADOG_CLIENT_TOKEN;
            const site = import.meta.env.PUBLIC_DATADOG_SITE || "datadoghq.com";

            if (applicationId && clientToken) {
                datadogRum.init({
                    applicationId,
                    clientToken,
                    site,
                    service: "arcbase-website",
                    env: import.meta.env.MODE || "production",
                    version: "1.0.0",
                    sessionSampleRate: 100,
                    sessionReplaySampleRate: 20,
                    trackUserInteractions: true,
                    trackResources: true,
                    trackLongTasks: true,
                    defaultPrivacyLevel: "mask-user-input",
                });
            }
        </script>

        <script>
            import Honeybadger from "@honeybadger-io/js";

            const hbApiKey = import.meta.env.PUBLIC_HONEYBADGER_API_KEY;

            Honeybadger.configure({
                apiKey: hbApiKey,
                environment: import.meta.env.MODE || "production",
            });
        </script>
    </head>

    <body>
        <a href="#main" class="skip-link">Skip to content</a>

        <!---
        
                <div class="announcement-banner">
            <div class="announcement-inner">
                <span class="announcement-text">
                    <strong>#KeepAndroidOpen</strong> — Android's open source future
                    is under threat.
                    <a href="/android" class="announcement-link">Learn more →</a
                    >
                </span>
            </div>
            <button class="announcement-close" aria-label="Close">×</button>
        </div>
        
        - -->

        <div id="cookie-banner" class="cookie-banner" style="display: none;">
            <div class="cookie-banner-content">
                <div class="cookie-banner-text">
                    <h3>We use cookies</h3>
                    <p>
                        We use cookies to enhance your browsing experience and
                        analyze our traffic. <a href="/cookies">Learn more</a>
                    </p>
                </div>
                <div class="cookie-banner-buttons">
                    <button id="cookie-manage" class="btn-cookie-link"
                        >Manage options</button
                    >
                    <button id="cookie-reject" class="btn-cookie-secondary"
                        >No thanks</button
                    >
                    <button id="cookie-accept" class="btn-cookie-primary"
                        >Agree</button
                    >
                </div>
            </div>
        </div>

        <div id="cookie-modal" class="cookie-modal" style="display: none;">
            <div class="cookie-modal-backdrop"></div>
            <div class="cookie-modal-content">
                <div class="cookie-modal-header">
                    <h2>Manage your privacy</h2>
                    <button id="cookie-modal-close" class="cookie-modal-close"
                        >×</button
                    >
                </div>
                <div class="cookie-modal-body">
                    <p>
                        We use cookies to improve your experience and analyze
                        site traffic. You can choose which cookies you want to
                        accept.
                    </p>

                    <div class="cookie-option">
                        <div class="cookie-option-info">
                            <h4>Necessary cookies</h4>
                            <p>
                                Required for the site to work. Cannot be
                                disabled.
                            </p>
                        </div>
                        <label class="cookie-toggle">
                            <input type="checkbox" checked disabled />
                            <span class="cookie-slider"></span>
                        </label>
                    </div>

                    <div class="cookie-option">
                        <div class="cookie-option-info">
                            <h4>Analytics cookies</h4>
                            <p>
                                Help us understand how visitors interact with
                                our website.
                            </p>
                        </div>
                        <label class="cookie-toggle">
                            <input type="checkbox" id="cookie-analytics" />
                            <span class="cookie-slider"></span>
                        </label>
                    </div>
                </div>
                <div class="cookie-modal-footer">
                    <button id="cookie-cancel" class="btn-cookie-link"
                        >Cancel</button
                    >
                    <button id="cookie-save" class="btn-cookie-primary"
                        >Save my preferences</button
                    >
                </div>
            </div>
        </div>

        <nav
            class={`navbar ${activePage !== "home" ? "navbar-dark" : ""}`}
            id="navbar"
            role="navigation"
            aria-label="Main Navigation"
        >
            <a href="/" class="nav-brand">
                <img
                    src="/logo.png"
                    alt="arcbase Logo"
                    height="32"
                    width="32"
                />
                <span style="font-family: Google sans;">Arcbase</span>
            </a>
            <ul class="nav-links" id="navLinks">
                <li class="nav-dropdown">
                    <a href="/projects" class="nav-dropdown-trigger"
                        >Projects <i class="fa-solid fa-chevron-down"></i></a
                    >
                    <div class="nav-dropdown-menu">
                        <a href="/projects">All Projects</a>
                        <a href="/projects/app">Arcbase Learning</a>
                        <a href="/projects/manager">Arc Manager</a>
                        <a href="/projects/os">ArcOS</a>
                        <a href="/projects/book">OpenShelf</a>
                        <a href="/projects/sentinel">Sentinel</a>
                        <a href="/cryfox">CryFox</a>
                    </div>
                </li>
                <li class="nav-dropdown">
                    <a href="/docs" class="nav-dropdown-trigger"
                        >Resources <i class="fa-solid fa-chevron-down"></i></a
                    >
                    <div class="nav-dropdown-menu">
                        <a href="/docs">Docs</a>
                        <a href="/blog">Blog</a>
                        <a href="/roadmap">Roadmap</a>
                        <a href="/android">Android</a>
                    </div>
                </li>
                <li>
                    <a
                        href="/about"
                        class={activePage === "about" ? "active" : ""}>About</a
                    >
                </li>
                <li>
                    <a
                        href="/contact"
                        class={activePage === "contact" ? "active" : ""}
                        >Contact</a
                    >
                </li>
                <li>
                    <a
                        href="https://github.com/arcbasehq"
                        target="_blank"
                        rel="noopener noreferrer">GitHub</a
                    >
                </li>
                <li class="nav-auth-divider" aria-hidden="true"></li>
                <li class="nav-auth-item" id="navAuthPrimary">
                    <a href="/login">Sign In</a>
                </li>
                <li class="nav-auth-item" id="navAuthSecondary">
                    <a href="/register">Sign Up</a>
                </li>
            </ul>
            <div class="nav-controls">
                <AuthButton />
                <button
                    class="theme-toggle"
                    id="themeToggle"
                    aria-label="Toggle Dark Mode"
                    aria-pressed="false"
                >
                    <svg
                        class="sun-icon"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <circle cx="12" cy="12" r="5"></circle>
                        <line x1="12" y1="1" x2="12" y2="3"></line>
                        <line x1="12" y1="21" x2="12" y2="23"></line>
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"
                        ></line>
                        <line x1="1" y1="12" x2="3" y2="12"></line>
                        <line x1="21" y1="12" x2="23" y2="12"></line>
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                    </svg>
                    <svg
                        class="moon-icon"
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                    >
                        <path
                            d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"
                        ></path>
                    </svg>
                </button>
                <button
                    class="mobile-toggle"
                    id="mobileToggle"
                    aria-label="Toggle Menu"
                    aria-controls="navLinks"
                    aria-expanded="false"
                >
                    <span></span>
                    <span></span>
                    <span></span>
                </button>
            </div>
        </nav>

        <main id="main">
            <slot />
        </main>

        <footer class="footer">
            <div class="footer-content">
                <div class="footer-brand">
                    <a href="/" class="nav-brand">
                        <img
                            src="/logo.png"
                            alt="arcbase Logo"
                            height="32"
                            width="32"
                        />
                        <span style="font-family: Google sans;">Arcbase</span>
                    </a>
                    <p>
                        Empowering everyone to change their world, by bringing
                        open source software to the masses.
                    </p>
                    <form class="footer-newsletter" id="footerNewsletter">
                        <input
                            type="email"
                            placeholder="Your email"
                            id="footerNewsletterEmail"
                            required
                        />
                        <button type="submit"
                            ><i class="fa-solid fa-arrow-right"></i></button
                        >
                    </form>
                    <p class="footer-newsletter-hint">
                        Get updates on our latest projects.
                    </p>
                </div>
                <div class="footer-col">
                    <h4>Projects</h4>
                    <a href="/projects/sentinel">Sentinel</a>
                    <a href="/projects/app">Arcbase Learning</a>
                    <a href="/projects/manager">Arc Manager</a>
                    <a href="/projects/os">ArcOS</a>
                    <a href="/projects/book">OpenShelf</a>
                    <a href="/projects/cryfox">Cryfox</a>
                </div>
                <div class="footer-col">
                    <h4>Community</h4>
                    <a
                        href="https://github.com/arcbasehq/"
                        target="_blank"
                        rel="noopener">GitHub</a
                    >
                    <a href="/docs">Docs</a>
                    <a href="/blog">Blog</a>
                    <a href="/roadmap">Roadmap</a>
                </div>
                <div class="footer-col">
                    <h4>Company</h4>
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                    <a href="/press">Press</a>
                    <a
                        href="https://arcbasestatus.statuspage.io/"
                        target="_blank">Status</a
                    >
                </div>
            </div>
            <div class="footer-bottom">
                <p>
                    © {new Date().getFullYear()} Arcbase. All rights reserved.
                </p>
                <div class="footer-legal">
                    <a href="/terms">Terms</a>
                    <a href="/privacy">Privacy</a>
                    <a href="/cookies">Cookies</a>
                </div>
                <div class="footer-socials">
                    <a
                        href="https://github.com/arcbasehq"
                        target="_blank"
                        rel="noopener"
                        aria-label="GitHub"
                    >
                        <svg viewBox="0 0 24 24"
                            ><path
                                d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="https://opencollective.com/arcbasehq"
                        target="_blank"
                        rel="noopener"
                        aria-label="Open Collective"
                        class="footer-social-icon"
                    >
                        <img src="/open.png" alt="Open Collective" />
                    </a>
                </div>
            </div>
        </footer>

        <script>
            const navbar = document.getElementById("navbar");
            window.addEventListener(
                "scroll",
                () => {
                    if (window.scrollY > 60) {
                        navbar?.classList.add("scrolled");
                    } else {
                        navbar?.classList.remove("scrolled");
                    }
                },
                { passive: true },
            );

            const mobileToggle = document.getElementById("mobileToggle");
            const navLinks = document.getElementById("navLinks");

            if (mobileToggle && navLinks) {
                mobileToggle.addEventListener("click", () => {
                    const active = navLinks.classList.toggle("active");
                    mobileToggle.classList.toggle("active");
                    mobileToggle.setAttribute(
                        "aria-expanded",
                        active ? "true" : "false",
                    );
                });

                navLinks.querySelectorAll("a").forEach((link) => {
                    link.addEventListener("click", () => {
                        navLinks.classList.remove("active");
                        mobileToggle.classList.remove("active");
                        mobileToggle.setAttribute("aria-expanded", "false");
                    });
                });

                document.addEventListener("click", (e) => {
                    if (
                        navLinks.classList.contains("active") &&
                        !navLinks.contains(e.target as Node) &&
                        !mobileToggle.contains(e.target as Node)
                    ) {
                        navLinks.classList.remove("active");
                        mobileToggle.classList.remove("active");
                        mobileToggle.setAttribute("aria-expanded", "false");
                    }
                });

                document.addEventListener("keydown", (e) => {
                    if (
                        e.key === "Escape" &&
                        navLinks.classList.contains("active")
                    ) {
                        navLinks.classList.remove("active");
                        mobileToggle.classList.remove("active");
                        mobileToggle.setAttribute("aria-expanded", "false");
                    }
                });
            }

            const fadeElements = document.querySelectorAll(".fade-up");
            const observer = new IntersectionObserver(
                (entries) => {
                    entries.forEach((entry) => {
                        if (entry.isIntersecting) {
                            entry.target.classList.add("visible");
                        }
                    });
                },
                { threshold: 0.1, rootMargin: "0px 0px -50px 0px" },
            );

            fadeElements.forEach((el) => observer.observe(el));

            const themeToggle = document.getElementById("themeToggle");
            const html = document.documentElement;

            const currentTheme = localStorage.getItem("theme") || "light";
            html.setAttribute("data-theme", currentTheme);

            if (themeToggle) {
                themeToggle.setAttribute(
                    "aria-pressed",
                    currentTheme === "dark" ? "true" : "false",
                );
            }

            themeToggle?.addEventListener("click", () => {
                const theme =
                    html.getAttribute("data-theme") === "light"
                        ? "dark"
                        : "light";
                html.setAttribute("data-theme", theme);
                localStorage.setItem("theme", theme);
                if (themeToggle) {
                    themeToggle.setAttribute(
                        "aria-pressed",
                        theme === "dark" ? "true" : "false",
                    );
                }
            });

            // Close banner functionality
            function updateLayout() {
                const banners = Array.from(
                    document.querySelectorAll(".announcement-banner"),
                ) as HTMLElement[];
                const navbar = document.getElementById("navbar");
                const body = document.body;

                // On mobile the navbar is pinned at top:0 via CSS and banners
                // flow in the document — only the navbar height (60px) needs
                // clearing. Let CSS handle the body offset.
                if (window.innerWidth <= 768) {
                    body.style.paddingTop = "60px";
                    if (navbar) navbar.style.removeProperty("top");
                    return;
                }

                // Restack visible banners from the top so that closing any
                // banner (not just the last one) never leaves a gap or overlap.
                let runningTop = 0;
                banners.forEach((banner) => {
                    if (banner.style.display === "none") return;
                    banner.style.top = runningTop + "px";
                    runningTop += banner.offsetHeight;
                });

                // runningTop now equals the total height of all visible banners
                if (navbar) {
                    navbar.style.top = runningTop + "px";
                }
                body.style.paddingTop = runningTop + 60 + "px";
            }

            // Also re-run layout logic when the viewport is resized
            window.addEventListener("resize", updateLayout, { passive: true });

            // Set initial states and add listeners
            document.addEventListener("DOMContentLoaded", () => {
                updateLayout();

                document
                    .querySelectorAll(".announcement-close")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const banner = btn.closest(".announcement-banner");
                            if (banner) {
                                (banner as HTMLElement).style.display = "none";
                                updateLayout();
                            }
                        });
                    });

                // Reflect auth state in the mobile dropdown
                (async () => {
                    try {
                        const { supabase } = await import("../lib/supabase");
                        const {
                            data: { user },
                        } = await supabase.auth.getUser();
                        const primary =
                            document.getElementById("navAuthPrimary");
                        const secondary =
                            document.getElementById("navAuthSecondary");
                        if (user) {
                            if (primary) {
                                const a = primary.querySelector("a");
                                if (a) {
                                    a.href = "/dashboard";
                                    a.textContent = "Dashboard";
                                }
                            }
                            secondary?.remove();
                        }
                    } catch {
                        // silently ignore — static links remain as fallback
                    }
                })();

                // Cookie banner logic
                const cookieBanner = document.getElementById("cookie-banner");
                const cookieModal = document.getElementById("cookie-modal");
                const cookieManage = document.getElementById("cookie-manage");
                const cookieModalClose =
                    document.getElementById("cookie-modal-close");
                const cookieAccept = document.getElementById("cookie-accept");
                const cookieReject = document.getElementById("cookie-reject");
                const cookieSave = document.getElementById("cookie-save");
                const cookieAnalytics =
                    document.getElementById("cookie-analytics");

                function getCookie(name: string): string | null {
                    const value = `; ${document.cookie}`;
                    const parts = value.split(`; ${name}=`);
                    if (parts.length === 2)
                        return (parts.pop()?.split(";").shift() as string) || null;
                    return null;
                }

                function setCookie(name: string, value: string, days: number = 365): void {
                    const expires = new Date();
                    expires.setTime(
                        expires.getTime() + days * 24 * 60 * 60 * 1000,
                    );
                    document.cookie = `${name}=${value};expires=${expires.toUTCString()};path=/;SameSite=Lax`;
                }

                function showCookieBanner() {
                    if (cookieBanner) cookieBanner.style.display = "block";
                }

                function hideCookieBanner() {
                    if (cookieBanner) cookieBanner.style.display = "none";
                }

                function showCookieModal() {
                    if (cookieModal) cookieModal.style.display = "flex";
                }

                function hideCookieModal() {
                    if (cookieModal) cookieModal.style.display = "none";
                }

                function applyCookiePreferences(analytics: boolean): void {
                    if (analytics) {
                        // Enable analytics
                    } else {
                        // Disable analytics
                    }
                }

                // Check if user has made a choice
                const cookieConsent = getCookie("cookie_consent");
                if (!cookieConsent) {
                    showCookieBanner();
                }

                // Event listeners
                cookieManage?.addEventListener("click", () => {
                    hideCookieBanner();
                    showCookieModal();
                });

                cookieModalClose?.addEventListener("click", () => {
                    hideCookieModal();
                    showCookieBanner();
                });
                document
                    .querySelector(".cookie-modal-backdrop")
                    ?.addEventListener("click", () => {
                        hideCookieModal();
                        showCookieBanner();
                    });

                cookieAccept?.addEventListener("click", () => {
                    setCookie("cookie_consent", "accepted", 365);
                    setCookie("cookie_analytics", "true", 365);
                    applyCookiePreferences(true);
                    hideCookieBanner();
                });

                cookieReject?.addEventListener("click", () => {
                    setCookie("cookie_consent", "rejected", 365);
                    setCookie("cookie_analytics", "false", 365);
                    applyCookiePreferences(false);
                    hideCookieBanner();
                });

                cookieSave?.addEventListener("click", () => {
                    const analytics = (cookieAnalytics as HTMLInputElement)?.checked || false;
                    setCookie("cookie_consent", "custom", 365);
                    setCookie(
                        "cookie_analytics",
                        analytics ? "true" : "false",
                        365,
                    );
                    applyCookiePreferences(analytics);
                    hideCookieModal();
                });

                // Cancel button
                const cookieCancel = document.getElementById("cookie-cancel");
                cookieCancel?.addEventListener("click", () => {
                    hideCookieModal();
                    showCookieBanner();
                });

                // Footer newsletter
                const footerForm = document.getElementById("footerNewsletter");
                footerForm?.addEventListener("submit", async (e) => {
                    e.preventDefault();
                    const email = (
                        document.getElementById(
                            "footerNewsletterEmail",
                        ) as HTMLInputElement
                    )?.value;
                    if (!email) return;
                    const btn = footerForm.querySelector("button");
                    if (btn) {
                        btn.disabled = true;
                        btn.innerHTML = '<i class="fa-solid fa-check"></i>';
                    }
                });
            });
        </script>
    </body>
</html>
