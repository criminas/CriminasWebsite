---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Dashboard"
    description="Your arcbase dashboard"
    activePage="dashboard"
>
    <div id="alertContainer" class="alert-container"></div>

    <section class="page-hero">
        <div class="page-hero-content fade-up">
            <h1>Dashboard</h1>
            <p id="welcomeMessage">Welcome back!</p>
        </div>
    </section>

    <section class="section">
        <div class="section-container">
            <!-- Ban Notice Banner -->
            <div
                id="bannedBanner"
                class="banned-banner"
                style="display: none;"
                role="alert"
                aria-live="assertive"
            >
                <div class="banned-banner-inner">
                    <svg
                        width="28"
                        height="28"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        aria-hidden="true"
                    >
                        <circle cx="12" cy="12" r="10"></circle>
                        <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                    </svg>
                    <div class="banned-banner-text">
                        <strong>Your account has been suspended.</strong>
                        <p id="banReasonText">
                            You are no longer able to interact with arcbase
                            services. Your profile information is still visible
                            below.
                        </p>
                    </div>
                </div>
                <p class="banned-appeal">
                    If you believe this is a mistake, please contact us at
                    <a href="mailto:arcbase@tuta.io">arcbase@tuta.io</a>.
                </p>
            </div>

            <div class="dashboard-grid">
                <!-- User Profile Card -->
                <div class="dashboard-card profile-card">
                    <div class="card-header">
                        <h2>Profile</h2>
                        <a href="#" id="editProfile" class="text-link">Edit</a>
                    </div>
                    <div class="profile-content" id="profileContent">
                        <div class="profile-avatar-wrapper">
                            <div class="profile-avatar" id="profileAvatar">
                            </div>
                            <button
                                class="avatar-edit-btn"
                                id="avatarEditBtn"
                                title="Change profile picture"
                            >
                                <svg
                                    width="14"
                                    height="14"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"
                                    ></path>
                                    <circle cx="12" cy="13" r="4"></circle>
                                </svg>
                            </button>
                            <input
                                type="file"
                                id="avatarFileInput"
                                accept="image/*"
                                style="display:none"
                            />
                        </div>
                        <div class="profile-info">
                            <h3 id="profileName">Loading...</h3>
                            <span
                                id="roleBadge"
                                class="role-badge"
                                style="display: none;"></span>
                            <p id="profileEmail"></p>
                        </div>
                    </div>
                    <div
                        id="profileMessage"
                        class="profile-message"
                        style="display: none;"
                    >
                    </div>
                    <div
                        class="profile-edit-form"
                        id="profileEditForm"
                        style="display: none;"
                    >
                        <div class="form-group">
                            <label for="editName">Name</label>
                            <input type="text" id="editName" />
                        </div>
                        <div class="form-actions">
                            <button class="btn-primary" id="saveProfile"
                                >Save</button
                            >
                            <button class="btn-secondary" id="cancelEdit"
                                >Cancel</button
                            >
                        </div>
                    </div>
                    <div
                        class="newsletter-status"
                        id="newsletterStatus"
                        style="display: none;"
                    >
                        <div class="newsletter-badge" id="newsletterBadge">
                            <svg
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <rect x="2" y="4" width="20" height="16" rx="2"
                                ></rect>
                                <path d="M22 4L12 13L2 4"></path>
                            </svg>
                            <span id="newsletterLabel">Newsletter</span>
                        </div>
                        <button class="newsletter-toggle" id="newsletterToggle"
                        ></button>
                    </div>
                </div>

                <!-- Starred Projects Card -->
                <div class="dashboard-card starred-card">
                    <div class="card-header">
                        <h2>Starred Projects</h2>
                        <a href="/projects" class="text-link">Browse All</a>
                    </div>
                    <div id="starredProjects" class="starred-list">
                        <div class="loading">Loading starred projects...</div>
                    </div>
                </div>

                <!-- Account Stats Card -->
                <div class="dashboard-card stats-card">
                    <div class="card-header">
                        <h2>Account Overview</h2>
                    </div>
                    <div class="stats-grid">
                        <div class="stat-item">
                            <div class="stat-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <rect
                                        x="3"
                                        y="4"
                                        width="18"
                                        height="18"
                                        rx="2"
                                        ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                            </div>
                            <div class="stat-info">
                                <span class="stat-label">Member Since</span>
                                <span class="stat-value" id="memberSince"
                                    >—</span
                                >
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="stat-info">
                                <span class="stat-label">Projects Starred</span>
                                <span class="stat-value" id="starCount">0</span>
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"
                                    ></path>
                                    <circle cx="12" cy="7" r="4"></circle>
                                </svg>
                            </div>
                            <div class="stat-info">
                                <span class="stat-label">Account Type</span>
                                <span
                                    class="stat-value account-type-badge"
                                    id="accountTypeDisplay">Community</span
                                >
                            </div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"
                                    ></path>
                                    <polyline points="7 10 12 15 17 10"
                                    ></polyline>
                                    <line x1="12" y1="15" x2="12" y2="3"></line>
                                </svg>
                            </div>
                            <div class="stat-info">
                                <span class="stat-label">Downloads</span>
                                <span class="stat-value" id="downloadCount"
                                    >—</span
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Activity Feed -->
                <div class="dashboard-card activity-card">
                    <div class="card-header">
                        <h2>Recent Activity</h2>
                    </div>
                    <div class="activity-feed" id="activityFeed">
                        <div class="activity-item">
                            <div class="activity-dot dot-green"></div>
                            <div class="activity-content">
                                <p>Account created</p>
                                <span
                                    class="activity-time"
                                    id="accountCreatedTime">—</span
                                >
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Downloads Card -->
                <div class="dashboard-card downloads-card">
                    <div class="card-header">
                        <h2>Available Downloads</h2>
                        <a href="/projects" class="text-link">All Projects</a>
                    </div>
                    <div class="downloads-list">
                        <a href="/projects/os" class="download-item">
                            <div class="download-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <rect
                                        x="2"
                                        y="3"
                                        width="20"
                                        height="14"
                                        rx="2"
                                        ry="2"></rect>
                                    <line x1="8" y1="21" x2="16" y2="21"></line>
                                    <line x1="12" y1="17" x2="12" y2="21"
                                    ></line>
                                </svg>
                            </div>
                            <div class="download-info">
                                <h3>ArcOS</h3>
                                <p>Desktop experience for everyone</p>
                            </div>
                            <svg
                                class="download-arrow"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                        <a href="/projects/sentinel" class="download-item">
                            <div class="download-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                                    ></path>
                                </svg>
                            </div>
                            <div class="download-info">
                                <h3>Sentinel</h3>
                                <p>Advanced security toolkit</p>
                            </div>
                            <svg
                                class="download-arrow"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                        <a href="/projects/manager" class="download-item">
                            <div class="download-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path
                                        d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                                    ></path>
                                    <polyline points="14 2 14 8 20 8"
                                    ></polyline>
                                </svg>
                            </div>
                            <div class="download-info">
                                <h3>File Manager</h3>
                                <p>Modern file management</p>
                            </div>
                            <svg
                                class="download-arrow"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                        <a href="/projects/app" class="download-item">
                            <div class="download-icon">
                                <svg
                                    width="20"
                                    height="20"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <rect
                                        x="5"
                                        y="2"
                                        width="14"
                                        height="20"
                                        rx="2"
                                        ry="2"></rect>
                                    <line x1="12" y1="18" x2="12.01" y2="18"
                                    ></line>
                                </svg>
                            </div>
                            <div class="download-info">
                                <h3>Mobile App</h3>
                                <p>Arcbase on the go</p>
                            </div>
                            <svg
                                class="download-arrow"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path d="M5 12h14M12 5l7 7-7 7"></path>
                            </svg>
                        </a>
                    </div>
                </div>

                <!-- Quick Actions Card (Moved Down) -->
                <div class="dashboard-card actions-card">
                    <div class="card-header">
                        <h2>Quick Actions</h2>
                    </div>
                    <div class="actions-grid">
                        <a href="/projects" class="action-item">
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
                                ></path>
                            </svg>
                            <div>
                                <h3>Explore Projects</h3>
                                <p>Discover open source tools</p>
                            </div>
                        </a>
                        <a
                            href="https://github.com/arcbasehq"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="action-item"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="currentColor"
                            >
                                <path
                                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                                ></path>
                            </svg>
                            <div>
                                <h3>View on GitHub</h3>
                                <p>See all repositories</p>
                            </div>
                        </a>
                        <a href="/contact" class="action-item">
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"
                                ></path>
                            </svg>
                            <div>
                                <h3>Get in Touch</h3>
                                <p>Contact the team</p>
                            </div>
                        </a>
                        <button
                            class="action-item sign-out-action"
                            id="signOutAction"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <path
                                    d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"
                                ></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            <div>
                                <h3>Sign Out</h3>
                                <p>Leave your session</p>
                            </div>
                        </button>
                        <button
                            class="action-item delete-account-action"
                            id="deleteAccountAction"
                        >
                            <svg
                                width="24"
                                height="24"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                            >
                                <polyline points="3 6 5 6 21 6"></polyline>
                                <path
                                    d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"
                                ></path>
                                <line x1="10" y1="11" x2="10" y2="17"></line>
                                <line x1="14" y1="11" x2="14" y2="17"></line>
                            </svg>
                            <div>
                                <h3>Delete Account</h3>
                                <p>Permanently remove account</p>
                            </div>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script>
    import { supabase } from "../lib/supabase";

    let currentUser: any = null;
    let userProfile: any = null;

    async function loadDashboard() {
        try {
            // Check authentication
            const {
                data: { user },
            } = await supabase.auth.getUser();

            if (!user) {
                console.debug(
                    "Dashboard: currentUser not found — redirecting to /login",
                );
                window.location.href = "/login";
                return;
            }
            currentUser = user;

            // Fetch extra profile data
            const { data: profile } = await supabase
                .from("profiles")
                .select("*")
                .eq("id", user.id)
                .single();

            userProfile = profile || {};

            // Check if the user has been banned by an admin
            const isBanned = userProfile.is_banned === true;

            // Update welcome message
            const welcomeMsg = document.getElementById("welcomeMessage");
            if (welcomeMsg) {
                welcomeMsg.textContent = isBanned
                    ? "Your account has been suspended."
                    : `Welcome back, ${userProfile.name || user.user_metadata?.full_name || "there"}!`;
            }

            // Update profile card (read-only for banned users)
            updateProfileCard();

            if (isBanned) {
                // Show ban notice, lock down the UI, then stop loading further data
                applyBanRestrictions(userProfile.ban_reason ?? undefined);
                loadAccountStats([]);
                return;
            }

            // Load starred projects
            const starredData = await loadStarredProjects();

            // Load newsletter status
            loadNewsletterStatus();

            // Load account stats
            loadAccountStats(starredData);
        } catch (error) {
            console.error("Error loading dashboard:", error);
            window.location.href = "/login";
        }
    }

    function loadAccountStats(starredData?: any[]) {
        if (!currentUser) return;

        // Member since
        const memberSince = document.getElementById("memberSince");
        if (memberSince && currentUser.created_at) {
            const date = new Date(currentUser.created_at);
            memberSince.textContent = date.toLocaleDateString("en-US", {
                month: "short",
                year: "numeric",
            });
        }

        // Star count
        const starCount = document.getElementById("starCount");
        if (starCount) {
            starCount.textContent = (starredData?.length || 0).toString();
        }

        // Download count
        const downloadCount = document.getElementById("downloadCount");
        if (downloadCount) {
            downloadCount.textContent = "0";
        }

        // Account type
        const accountType = document.getElementById("accountTypeDisplay");
        if (accountType) {
            const role = userProfile.role || "Community";
            accountType.textContent =
                role.charAt(0).toUpperCase() + role.slice(1);
        }

        // Account created time in activity feed
        const accountCreatedTime =
            document.getElementById("accountCreatedTime");
        const activityFeed = document.getElementById("activityFeed");

        if (accountCreatedTime && currentUser.created_at) {
            const date = new Date(currentUser.created_at);
            accountCreatedTime.textContent = date.toLocaleDateString("en-US", {
                month: "long",
                day: "numeric",
                year: "numeric",
            });
        } else if (activityFeed) {
            // Fallback clear
            activityFeed.innerHTML = "";
        }

        // Add starred activity items
        if (activityFeed && starredData && starredData.length > 0) {
            const starItem = document.createElement("div");
            starItem.className = "activity-item";
            starItem.innerHTML = `
                <div class="activity-dot dot-blue"></div>
                <div class="activity-content"><p>Starred ${starredData.length} project${starredData.length === 1 ? "" : "s"}</p><span class="activity-time">Recent</span></div>
            `;
            activityFeed.insertBefore(starItem, activityFeed.firstChild);
        }

        if (userProfile.newsletter_subscribed) {
            const nlItem = document.createElement("div");
            nlItem.className = "activity-item";
            nlItem.innerHTML = `
                <div class="activity-dot dot-purple"></div>
                <div class="activity-content"><p>Subscribed to newsletter</p><span class="activity-time">Active</span></div>
            `;
            activityFeed?.insertBefore(nlItem, activityFeed.firstChild);
        }
    }

    /**
     * Applies visual and functional restrictions to the dashboard when a user
     * is banned. Shows the ban banner and disables all interactive controls
     * except sign-out.
     */
    function applyBanRestrictions(reason?: string) {
        // Show the ban banner
        const banner = document.getElementById("bannedBanner");
        if (banner) banner.style.display = "flex";

        // Show the ban reason if one was provided by the admin
        if (reason) {
            const reasonEl = document.getElementById("banReasonText");
            if (reasonEl) reasonEl.textContent = `Reason: ${reason}`;
        }

        // Mark the grid so CSS can visually dim interactive cards
        document.querySelector(".dashboard-grid")?.classList.add("is-banned");

        // Disable the "Edit" profile link
        const editProfileLink = document.getElementById(
            "editProfile",
        ) as HTMLAnchorElement;
        if (editProfileLink) {
            editProfileLink.removeAttribute("href");
            editProfileLink.classList.add("banned-control");
            editProfileLink.title = "Account suspended";
        }

        // Hide the avatar upload button
        const avatarBtn = document.getElementById(
            "avatarEditBtn",
        ) as HTMLButtonElement;
        if (avatarBtn) avatarBtn.style.display = "none";

        // Replace starred projects panel with a restricted message
        const starredContainer = document.getElementById("starredProjects");
        if (starredContainer) {
            starredContainer.innerHTML = `
                <div class="ban-restricted-msg">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                    </svg>
                    <p>Starred projects are unavailable while your account is suspended.</p>
                </div>`;
        }

        // Disable all quick action items except sign-out
        document.querySelectorAll<HTMLElement>(".action-item").forEach((el) => {
            if (el.id === "signOutAction") return;
            el.classList.add("banned-control");
            el.setAttribute("tabindex", "-1");
            el.setAttribute("aria-disabled", "true");
            if (el.tagName === "BUTTON")
                (el as HTMLButtonElement).disabled = true;
            if (el.tagName === "A") el.removeAttribute("href");
        });

        // Disable download links
        document
            .querySelectorAll<HTMLElement>(".download-item")
            .forEach((el) => {
                el.classList.add("banned-control");
                el.setAttribute("tabindex", "-1");
                el.setAttribute("aria-disabled", "true");
                el.removeAttribute("href");
            });

        // Disable the delete account button
        const deleteBtn = document.getElementById(
            "deleteAccountAction",
        ) as HTMLButtonElement;
        if (deleteBtn) {
            deleteBtn.disabled = true;
            deleteBtn.title = "Account suspended — contact arcbase@tuta.io";
        }
    }

    function updateProfileCard() {
        if (!currentUser) return;

        const avatar = document.getElementById("profileAvatar");
        const name = document.getElementById("profileName");
        const email = document.getElementById("profileEmail");

        const displayName =
            userProfile.name || currentUser.user_metadata?.full_name || "User";
        const displayImage =
            userProfile.image || currentUser.user_metadata?.avatar_url;

        if (avatar) {
            if (displayImage) {
                avatar.innerHTML = `<img src="${displayImage}" alt="${displayName}" />`;
            } else {
                avatar.innerHTML = `<span>${displayName[0].toUpperCase()}</span>`;
            }
        }

        if (name) name.textContent = displayName;
        if (email) email.textContent = currentUser.email || "";

        const roleBadge = document.getElementById("roleBadge");
        if (roleBadge) {
            if (userProfile.role) {
                roleBadge.textContent =
                    userProfile.role.charAt(0).toUpperCase() +
                    userProfile.role.slice(1);
                roleBadge.style.display = "inline-block";
            } else {
                roleBadge.style.display = "none";
            }
        }

        // Setup avatar upload
        const avatarBtn = document.getElementById("avatarEditBtn");
        const avatarInput = document.getElementById(
            "avatarFileInput",
        ) as HTMLInputElement;
        avatarBtn?.addEventListener("click", () => avatarInput?.click());
        avatarInput?.addEventListener("change", handleAvatarUpload);
    }

    async function handleAvatarUpload(e: Event) {
        const input = e.target as HTMLInputElement;
        const file = input.files?.[0];
        if (!file || !currentUser) return;

        // Validate
        if (!file.type.startsWith("image/")) {
            showAlert("Please select an image file.", "error");
            return;
        }
        if (file.size > 5 * 1024 * 1024) {
            showAlert("Image must be under 5MB.", "error");
            return;
        }

        try {
            // Show inline loading state
            const msgEl = document.getElementById("profileMessage");
            if (msgEl) {
                msgEl.textContent = "Uploading...";
                msgEl.className = "profile-message info";
                msgEl.style.display = "block";
            }

            // Upload via Supabase Storage
            const fileExt = file.name.split(".").pop();
            const fileName = `${currentUser.id}-${Math.random()}.${fileExt}`;
            const { data: uploadData, error: uploadError } =
                await supabase.storage
                    .from("avatars")
                    .upload(fileName, file, { upsert: true });

            if (uploadError) throw uploadError;

            // Get public URL
            const { data: publicUrlData } = supabase.storage
                .from("avatars")
                .getPublicUrl(uploadData.path);

            const url = publicUrlData.publicUrl;

            // Update user profile
            const { error: updateError } = await supabase
                .from("profiles")
                .update({ image: url })
                .eq("id", currentUser.id);

            if (updateError) throw updateError;

            // Update UI
            userProfile.image = url;
            const avatar = document.getElementById("profileAvatar");
            const displayName =
                userProfile.name ||
                currentUser.user_metadata?.full_name ||
                "User";
            if (avatar) {
                avatar.innerHTML = `<img src="${url}" alt="${displayName}" />`;
            }

            if (msgEl) {
                msgEl.textContent = "Profile picture updated!";
                msgEl.className = "profile-message success";
                setTimeout(() => {
                    msgEl.style.display = "none";
                }, 3000);
            }
        } catch (error) {
            console.error("Avatar upload error:", error);
            const msgEl = document.getElementById("profileMessage");
            if (msgEl) {
                msgEl.textContent = "Failed to upload image.";
                msgEl.className = "profile-message error";
                msgEl.style.display = "block";
                setTimeout(() => {
                    msgEl.style.display = "none";
                }, 3000);
            }
        }

        input.value = "";
    }

    async function loadStarredProjects() {
        const container = document.getElementById("starredProjects");
        if (!container || !currentUser) return [];

        try {
            const { data: starred, error } = await supabase
                .from("starred_projects")
                .select("*")
                .order("starred_at", { ascending: false });

            if (error) throw error;

            if (!starred || starred.length === 0) {
                container.innerHTML = `
                    <div class="empty-state">
                        <p>No starred projects yet</p>
                        <a href="/projects" class="btn-secondary">Browse Projects</a>
                    </div>
                `;
                return [];
            }

            container.innerHTML = starred
                .slice(0, 5)
                .map(
                    (project: any) => `
                <div class="starred-item">
                    <div class="starred-info">
                        <h4>${escapeHtml(project.project_name)}</h4>
                        <p class="starred-date">${formatDate(project.starred_at)}</p>
                    </div>
                    <button class="unstar-btn" data-project-id="${escapeHtml(project.project_id)}">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
                            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                        </svg>
                        Unstar
                    </button>
                </div>
            `,
                )
                .join("");

            // Add unstar listeners
            document.querySelectorAll(".unstar-btn").forEach((btn) => {
                btn.addEventListener("click", async (e) => {
                    const projectId = (e.currentTarget as HTMLButtonElement)
                        .dataset.projectId;
                    if (projectId) {
                        await supabase
                            .from("starred_projects")
                            .delete()
                            .eq("project_id", projectId)
                            .eq("user_id", currentUser.id);

                        const newData = await loadStarredProjects();
                        loadAccountStats(newData);
                    }
                });
            });

            return starred;
        } catch (error) {
            console.error("Error loading starred projects:", error);
            container.innerHTML =
                '<div class="error">Failed to load projects</div>';
            return [];
        }
    }

    async function loadNewsletterStatus() {
        const statusEl = document.getElementById("newsletterStatus");
        const badge = document.getElementById("newsletterBadge");
        const label = document.getElementById("newsletterLabel");
        const toggle = document.getElementById(
            "newsletterToggle",
        ) as HTMLButtonElement;

        if (!statusEl || !badge || !label || !toggle || !currentUser) return;

        let isSubscribed = userProfile?.newsletter_subscribed ?? false;
        statusEl.style.display = "flex";

        updateNewsletterUI(isSubscribed, badge, label, toggle);

        toggle.addEventListener("click", async () => {
            toggle.disabled = true;
            try {
                if (isSubscribed) {
                    await supabase
                        .from("newsletter_subscriptions")
                        .delete()
                        .eq("email", currentUser.email);

                    await supabase
                        .from("profiles")
                        .update({ newsletter_subscribed: false })
                        .eq("id", currentUser.id);

                    isSubscribed = false;
                } else {
                    await supabase
                        .from("newsletter_subscriptions")
                        .upsert({ email: currentUser.email });

                    await supabase
                        .from("profiles")
                        .update({ newsletter_subscribed: true })
                        .eq("id", currentUser.id);

                    isSubscribed = true;
                }
                userProfile.newsletter_subscribed = isSubscribed;
                updateNewsletterUI(isSubscribed, badge, label, toggle);
            } catch (error) {
                console.error("Error toggling newsletter:", error);
                showAlert("Failed to update newsletter preference.", "error");
            }
            toggle.disabled = false;
        });
    }

    function updateNewsletterUI(
        subscribed: boolean,
        badge: HTMLElement,
        label: HTMLElement,
        toggle: HTMLButtonElement,
    ) {
        if (subscribed) {
            badge.classList.add("subscribed");
            badge.classList.remove("not-subscribed");
            label.textContent = "Subscribed";
            toggle.textContent = "Unsubscribe";
            toggle.classList.add("unsub");
        } else {
            badge.classList.remove("subscribed");
            badge.classList.add("not-subscribed");
            label.textContent = "Not subscribed";
            toggle.textContent = "Subscribe";
            toggle.classList.remove("unsub");
        }
    }

    function escapeHtml(text: string): string {
        const div = document.createElement("div");
        div.textContent = text;
        return div.innerHTML;
    }

    function formatDate(timestamp: string | number): string {
        const date = new Date(timestamp);
        const now = new Date();
        const diff = now.getTime() - date.getTime();
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));

        if (days === 0) return "starred today";
        if (days === 1) return "starred yesterday";
        if (days < 7) return `starred ${days} days ago`;
        return `starred ${date.toLocaleDateString()}`;
    }

    // Profile edit functionality
    document.getElementById("editProfile")?.addEventListener("click", (e) => {
        e.preventDefault();
        const content = document.getElementById("profileContent");
        const form = document.getElementById("profileEditForm");
        const editName = document.getElementById(
            "editName",
        ) as HTMLInputElement;

        if (content && form && editName) {
            content.style.display = "none";
            form.style.display = "block";
            editName.value =
                userProfile?.name ||
                currentUser?.user_metadata?.full_name ||
                "";
        }
    });

    document.getElementById("cancelEdit")?.addEventListener("click", () => {
        const content = document.getElementById("profileContent");
        const form = document.getElementById("profileEditForm");

        if (content && form) {
            content.style.display = "flex";
            form.style.display = "none";
        }
    });

    document
        .getElementById("saveProfile")
        ?.addEventListener("click", async () => {
            const editName = document.getElementById(
                "editName",
            ) as HTMLInputElement;
            const name = editName?.value;

            if (name && currentUser) {
                try {
                    await supabase
                        .from("profiles")
                        .update({ name })
                        .eq("id", currentUser.id);

                    userProfile.name = name;
                    updateProfileCard();

                    const content = document.getElementById("profileContent");
                    const form = document.getElementById("profileEditForm");

                    if (content && form) {
                        content.style.display = "flex";
                        form.style.display = "none";
                    }
                } catch (error) {
                    console.error("Error updating profile:", error);
                    showAlert(
                        "Failed to update profile. Please try again.",
                        "error",
                    );
                }
            }
        });

    // Sign out
    document
        .getElementById("signOutAction")
        ?.addEventListener("click", async () => {
            try {
                await supabase.auth.signOut();
                window.location.href = "/";
            } catch (error) {
                console.error("Error signing out:", error);
                window.location.href = "/";
            }
        });

    // Delete account
    document
        .getElementById("deleteAccountAction")
        ?.addEventListener("click", async () => {
            try {
                if (!currentUser) return;
                // Best effort delete profiles/auth user via standard tools might fail without an admin API
                // we will drop their profile info or user_metadata at minimum
                await supabase
                    .from("profiles")
                    .delete()
                    .eq("id", currentUser.id);
                await supabase.auth.signOut();

                showAlert(
                    "Account information deleted successfully. Redirecting...",
                    "success",
                );
                setTimeout(() => {
                    window.location.href = "/";
                }, 1500);
            } catch (error) {
                console.error("Error deleting account:", error);
                showAlert(
                    "Failed to delete account data. Please try again.",
                    "error",
                );
            }
        });

    function showAlert(message: string, type: "success" | "error") {
        const alertContainer = document.getElementById("alertContainer");
        if (!alertContainer) return;

        const alert = document.createElement("div");
        alert.className = `alert alert-${type}`;
        alert.textContent = message;

        alertContainer.appendChild(alert);

        setTimeout(() => {
            alert.classList.add("fade-out");
            setTimeout(() => alert.remove(), 300);
        }, 3000);
    }

    // Load dashboard on page load
    document.addEventListener("DOMContentLoaded", loadDashboard);
</script>

