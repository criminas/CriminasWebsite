---
import Layout from "../layouts/Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
---

<Layout
  title="arcbase — Empowering Everyone to Change Their World"
  description="Arcbase brings open source software to the masses. Explore our projects in Linux, developer tools, and web services."
  keywords="arcbase, open source, linux, software, community, developer tools, web services"
  activePage="home"
>
  <!-- HERO -->
  <section class="hero">
    <div class="section-container">
      <div class="hero-content">
        <a
          href="https://github.com/arcbasehq/"
          target="_blank"
          rel="noopener"
          class="hero-badge"
        >
          <svg viewBox="0 0 24 24" width="14" height="14"
            ><path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          <span>Star us on GitHub</span>
        </a>
        <h1>
          Build with <span class="highlight">clarity</span>, ship with
          confidence.
        </h1>
        <p class="hero-subtitle">
          arcbase designs open tools that feel intentional—combining careful
          engineering with a sharp, modern experience for everyone.
        </p>
        <div class="hero-actions">
          <a href="/projects" class="btn-primary">
            Explore projects
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              ><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a href="/about" class="btn-secondary">See how we work</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section about-section">
    <div class="section-container">
      <div class="section-number fade-up">About</div>
      <div class="about-grid">
        <div class="about-text fade-up">
          <h2 class="section-title">Who are we?</h2>
          <p class="section-desc">
            Arcbase is more than just a typical software studio. We're a team, a
            movement, and a global community of enthusiasts. Together, we have a
            shared mission of bringing high-quality open source software to the
            everyday person. We work towards this goal by building
            professional-grade software, products, communities, and coalitions
            that challenge the existing tech status quo.
          </p>
          <p class="section-desc" style="margin-top: 16px;">
            Our current focus is in the developer tools, kernel-level
            optimizations, and web services space. We take on any endeavor that
            furthers our goals of digital sovereignty and user empowerment. By
            removing the barriers to entry, we're making it possible for anyone,
            regardless of technical background, to build their digital life
            on a foundation they actually own.
          </p>

          <div class="faq-section">
            <details class="faq-item">
              <summary class="faq-question">
                Do we make iOS apps?
                <svg
                  class="faq-icon"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </summary>
              <div class="faq-answer">
                <p>
                  No. We don't play in walled gardens or proprietary ecosystems
                  that restrict user freedom. We're exclusively focused on open
                  ecosystems like Android and Linux. In our view, software
                  should be transparent and accountable to the person using it,
                  not the corporation selling it.
                </p>
              </div>
            </details>
          </div>

          <a href="/about" class="about-link" style="margin-top: 20px;">
            See our journey <span>→</span>
          </a>
        </div>
        <div class="about-visual fade-up">
          <div class="about-card">
            <div class="about-stats">
              <div class="stat-item">
                <div class="stat-number">100%</div>
                <div class="stat-label">Open Source</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">∞</div>
                <div class="stat-label">Possibilities</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Community</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">0</div>
                <div class="stat-label">Barriers</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES -->
  <section class="section principles-section">
    <div class="section-container">
      <div class="section-number fade-up">Principles</div>
      <h2 class="section-title fade-up">What we believe</h2>
      <p class="section-desc fade-up">
        Everything we build and ship is guided by a core philosophy
        of simplicity and ownership. We believe that when you understand your tools
        with clarity, you gain the confidence to innovate without fear.
      </p>

      <div class="principles-grid">
        <div class="principle-card fade-up">
          <h3>Built for Clarity</h3>
          <p>
            We eliminate "black box" engineering. By keeping our source code
            open and our documentation accessible, we provide users with the
            clarity needed to audit their own security and privacy.
          </p>
        </div>

        <div class="principle-card fade-up">
          <h3>Shipped with Confidence</h3>
          <p>
            You should never have to wonder if an update will break your
            workflow. We rigorously test every tool we ship, ensuring you
            can move fast with confidence.
          </p>
        </div>

        <div class="principle-card fade-up">
          <h3>Community Owned</h3>
          <p>
            Arcbase is a coalition of developers and enthusiasts. Our roadmaps
            are shaped by the community, not by corporate boardrooms or
            advertising bottom lines.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section projects-section">
    <div class="section-container">
      <div class="section-number fade-up">Projects</div>
      <div class="projects-header fade-up">
        <div>
          <h2 class="section-title">What do we build?</h2>
          <p class="section-desc">
            We build products that innovate past the status quo. Everything we
            build is open source and developed with the community.
          </p>
        </div>
        <a href="/projects" class="about-link"
          >View all <span>→</span></a
        >
      </div>
      <div class="projects-grid">
        <a href="/projects/sentinel" class="project-card fade-up">
          <h3>Sentinel</h3>
          <p>
            A comprehensive suite of open source security tools designed for
            the modern web. Automated auditing, dependency tracking, and real-time vulnerability scanning.
          </p>
        </a>
        <a href="/projects/app" class="project-card fade-up">
          <span class="dev-badge">Android</span>
          <h3>Arcbase Learning</h3>
          <p>
            Master coding and system engineering on the go. Interactive learning playground with a community-driven curriculum.
          </p>
        </a>
        <a href="/projects/manager" class="project-card fade-up">
          <h3>Arcbase Manager</h3>
          <p>
            The ultimate Linux package manager frontend. Brings pacman, apt, dnf, and the AUR together under one interface.
          </p>
        </a>
        <a href="/projects/os" class="project-card fade-up">
          <h3>ArcOS</h3>
          <p>
            A professional Windows configuration framework for reproducible, performance-focused system profiles.
          </p>
        </a>
        <a href="/projects/book" class="project-card fade-up">
          <h3>OpenShelf</h3>
          <p>
            The privacy-focused community library. Free and open source cataloging tool for your digital collections.
          </p>
        </a>
        <a href="/projects/security" class="project-card fade-up">
          <h3>ArcSecurity</h3>
          <p>
            Advanced OSINT and footprint analysis tools for transparent, community-vetted security research.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="section mission-section">
    <div class="section-container">
      <div class="section-number fade-up">Mission</div>
      <h2 class="section-title fade-up">The Open Source Mission</h2>
      <p class="section-desc fade-up" style="max-width: 720px;">
        For too long, the digital world has been divided into walled gardens
        and proprietary "black boxes." We believe that true technological
        progress is only possible when the foundation is open, transparent,
        and owned by everyone. This isn't just about code—it's about the
        confidence of knowing exactly what your devices are doing.
      </p>
      <p class="section-desc fade-up" style="max-width: 720px; margin-top: 16px;">
        Our focus on the Linux and Android ecosystems stems from a simple core
        belief: users should have the clarity to audit, modify, and improve
        the tools they use every day.
      </p>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="section-container">
      <div class="section-number fade-up">Contact</div>
      <div class="contact-grid">
        <div class="contact-info fade-up">
          <h2 class="section-title">Questions?</h2>
          <p class="section-desc">
            Need support, want to ask questions, want to contribute, or just
            want to say hello? Reach out to us through any of these channels.
          </p>
          <div class="contact-channels">
            <a href="mailto:arcbase@tuta.io" class="contact-channel">
              <div class="channel-icon email">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  ></path></svg
                >
              </div>
              <div class="channel-text">
                <h4>Email</h4>
                <p>arcbase@tuta.io</p>
              </div>
            </a>
            <a
              href="https://github.com/arcbasehq"
              target="_blank"
              rel="noopener"
              class="contact-channel"
            >
              <div class="channel-icon github">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                  ></path></svg
                >
              </div>
              <div class="channel-text">
                <h4>GitHub</h4>
                <p>Browse our repositories</p>
              </div>
            </a>
          </div>
        </div>
        <div class="contact-form-card fade-up">
          <form id="contactForm">
            <div class="form-group">
              <label for="email">Email</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" required />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="What's this about?" />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell us what's on your mind..." required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <NewsletterSignup />

  <script>
    const contactFormEl = document.getElementById("contactForm") as HTMLFormElement;
    if (contactFormEl) {
      contactFormEl.addEventListener("submit", async function (e) {
        e.preventDefault();
        const btn = contactFormEl.querySelector(".form-submit") as HTMLButtonElement;
        const formData = new FormData(contactFormEl);
        const email = formData.get("email") as string;
        const subject = formData.get("subject") as string;
        const message = formData.get("message") as string;

        if (!email || !message) return;

        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = "Sending...";

        try {
          const { submitContactForm } = await import("../lib/actions");
          await submitContactForm({ email, subject, message });
          btn.textContent = "Sent!";
          contactFormEl.reset();
          setTimeout(function () {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 3000);
        } catch (error) {
          console.error("Form submission failed:", error);
          btn.textContent = "Error";
          setTimeout(function () {
            btn.textContent = originalText;
            btn.disabled = false;
          }, 3000);
        }
      });
    }
  </script>

  <style>
    .principles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 20px;
      margin-top: 32px;
    }

    .principle-card {
      background: var(--surface);
      padding: 28px;
      border-radius: var(--radius-lg);
      border: 1px solid var(--border);
      transition: all 0.2s ease;
    }

    .principle-card:hover {
      border-color: var(--border-strong);
      box-shadow: var(--shadow-md);
    }

    .principle-card h3 {
      font-size: 1.125rem;
      font-weight: 600;
      margin-bottom: 12px;
      color: var(--text-primary);
    }

    .principle-card p {
      color: var(--text-secondary);
      font-size: 0.9375rem;
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      .principles-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>