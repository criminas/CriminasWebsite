---
import Layout from "../layouts/Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
import HeroCanvas from "../components/HeroCanvas.astro";
---

<Layout
  title="arcbase — Empowering Everyone to Change Their World"
  description="Arcbase brings open source software to the masses. Explore our projects in Linux, developer tools, and web services."
  keywords="arcbase, open source, linux, software, community, developer tools, web services"
  activePage="home"
>
  <Fragment slot="head">
    <meta
      name="google-site-verification"
      content="nCsiokLgAVAxjdF8y8bD2O9WksrA0JD3j3fULgaEItY"
    />
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg">
      <canvas id="heroCanvas" aria-hidden="true" role="presentation"></canvas>
    </div>
    <div class="section-container">
      <div class="hero-content fade-up">
        <a
          href="https://github.com/arcbasehq/"
          target="_blank"
          rel="noopener"
          class="hero-badge"
        >
          <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"
            ><path
              d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
            ></path></svg
          >
          <span>Star us on GitHub</span>
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            ><path d="M7 17l9.2-9.2M17 17V7.8H7.8"></path></svg
          >
        </a>
        <h1>
          Build with <span class="highlight">clarity</span>, ship with
          confidence.
        </h1>
        <p class="hero-subtitle">
          arcbase designs open tools that feel intentional-combining careful
          engineering with a sharp, modern experience for everyone.
        </p>
        <div class="hero-actions">
          <a href="/projects" class="btn-primary">
            Explore projects
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"></path></svg
            >
          </a>
          <a href="/about" class="btn-secondary">See how we work</a>
        </div>
      </div>
    </div>
    <div class="hero-scroll-indicator">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>
  <!-- ABOUT -->
  <section class="section about-section" id="about">
    <div class="section-container">
      <div class="section-number fade-up">00</div>
      <div class="about-grid">
        <div class="about-text fade-up">
          <h2 class="section-title">Who are we?</h2>
          <p class="section-desc">
            Arcbase is more than just a typical software studio. We're a team, a
            movement, and a global community of enthusiasts. Together, we have a
            shared mission of bringing high-quality open source software to the
            everyday person. We work towards this goal by building
            professional-grade software, products, communities, and coalitions
            that challenge the existing tech status quo.
          </p>
          <p class="section-desc" style="margin-top: 1rem;">
            Our current focus is in the developer tools, kernel-level
            optimizations, and web services space. We take on any endeavor that
            furthers our goals of digital sovereignty and user empowerment. By
            removing the barriers to entry, we're making it possible for anyone,
            regardless of technical background, to <b>build</b> their digital life
            on a foundation they actually own.
          </p>

          <div class="faq-section" style="margin-top: 2rem;">
            <details class="faq-item">
              <summary class="faq-question">
                Do we make iOS apps?
                <svg
                  class="faq-icon"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d="M6 9l6 6 6-6"></path>
                </svg>
              </summary>
              <div class="faq-answer">
                <p>
                  No. We don't play in walled gardens or proprietary ecosystems
                  that restrict user freedom. We're exclusively focused on open
                  ecosystems like Android and Linux. In our view, software
                  should be transparent and accountable to the person using it,
                  not the corporation selling it.
                </p>
              </div>
            </details>
          </div>

          <a
            href="/about"
            class="about-link"
            style="margin-top: 1.5rem; display: inline-flex;"
          >
            See our journey <span class="arrow">→</span>
          </a>
        </div>
        <div class="about-visual fade-up">
          <div class="about-card">
            <div class="about-stats">
              <div class="stat-item">
                <div class="stat-number">100%</div>
                <div class="stat-label">Open Source</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">∞</div>
                <div class="stat-label">Possibilities</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">24/7</div>
                <div class="stat-label">Community</div>
              </div>
              <div class="stat-item">
                <div class="stat-number">0</div>
                <div class="stat-label">Barriers</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRINCIPLES (NEW SECTION FOR SEO) -->
  <section class="section principles-section">
    <div class="section-container">
      <div class="section-number fade-up">01</div>
      <h2 class="section-title fade-up">Our Principles</h2>
      <p
        class="section-desc fade-up"
        style="max-width: 600px; margin-bottom: 3rem;"
      >
        Everything we <b>build</b> and <b>ship</b> is guided by a core philosophy
        of simplicity and ownership. We believe that when you understand your tools
        with
        <b>clarity</b>, you gain the <b>confidence</b> to innovate without fear.
      </p>

      <div class="principles-grid">
        <div class="principle-card fade-up">
          <div class="principle-icon">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <circle cx="12" cy="12" r="10"></circle>
              <line x1="12" y1="8" x2="12" y2="12"></line>
              <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
          </div>
          <h3>Built for Clarity</h3>
          <p>
            We eliminate "black box" engineering. By keeping our source code
            open and our documentation accessible, we provide users with the
            <b>clarity</b> needed to audit their own security and privacy.
          </p>
        </div>

        <div class="principle-card fade-up">
          <div class="principle-icon">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            </svg>
          </div>
          <h3>Shipped with Confidence</h3>
          <p>
            You should never have to wonder if an update will break your
            workflow. We rigorously test every tool we <b>ship</b>, ensuring you
            can move fast with <b>confidence</b>.
          </p>
        </div>

        <div class="principle-card fade-up">
          <div class="principle-icon">
            <svg
              viewBox="0 0 24 24"
              width="24"
              height="24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
              <circle cx="9" cy="7" r="4"></circle>
              <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
          </div>
          <h3>Community Owned</h3>
          <p>
            Arcbase is a coalition of developers and enthusiasts. Our roadmaps
            are shaped by the community, not by corporate boardrooms or
            advertising bottom lines.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="section projects-section" id="projects">
    <div class="section-container">
      <div class="section-number fade-up">02</div>
      <div class="projects-header fade-up">
        <div>
          <h2 class="section-title">What do we do?</h2>
          <p class="section-desc">
            We build products that innovate past the status quo. Everything we
            build is open source and developed with the community.
          </p>
        </div>
        <a href="/projects" class="about-link"
          >View all projects <span class="arrow">→</span></a
        >
      </div>
      <div class="projects-grid">
        <a href="/projects/sentinel" class="project-card card-dark fade-up">
          <div class="project-card-bg"></div>
          <div class="project-card-content">
            <h3>Sentinel</h3>
            <p>
              A comprehensive suite of open source security tools designed for
              the modern web. Sentinel provides automated auditing, dependency
              tracking, and real-time vulnerability scanning to ensure your
              digital infrastructure remains resilient.
            </p>
          </div>
        </a>
        <a href="/projects/app" class="project-card card-green fade-up">
          <div class="project-card-bg"></div>
          <span class="dev-badge">Android Only</span>
          <div class="project-card-content">
            <h3>Arcbase Learning</h3>
            <p>
              Master coding and system engineering on the go. This interactive
              learning playground features a community-driven curriculum focused
              on the Linux ecosystem, Rust, and low-level
              development—exclusively for Android.
            </p>
          </div>
        </a>
        <a href="/projects/manager" class="project-card card-green fade-up">
          <div class="project-card-bg"></div>
          <div class="project-card-content">
            <h3>Arcbase Manager</h3>
            <p>
              The ultimate Linux package manager frontend. Arcbase Manager
              brings pacman, apt, dnf, and the AUR together under one
              consistent, professional interface, simplifying complex system
              maintenance for every user.
            </p>
          </div>
        </a>
        <a href="/projects/analysis" class="project-card card-green fade-up">
          <div class="project-card-bg"></div>
          <div class="dev-badge">In development</div>
          <div class="project-card-content">
            <h3>Arcbase Analysis AI</h3>
            <p>
              A privacy-first, local-only AI that analyzes your system logs to
              provide intelligent insights. Optimize performance, harden
              security, and <b>build</b> a more efficient Linux environment with automated,
              non-intrusive diagnostics.
            </p>
          </div>
        </a>
        <a href="/projects/os" class="project-card card-dark fade-up">
          <div class="project-card-bg"></div>
          <img
            src="/arcos.png"
            alt="ArcOS Logo"
            style="width: 60px; height: 60px;"
            loading="lazy"
            decoding="async"
          />
          <div class="project-card-content">
            <h3>ArcOS</h3>
            <p>
              A professional Windows configuration framework. ArcOS provides a
              reproducible, deterministic way to <b>ship</b> a performance-focused
              system profile, ensuring <b>clarity</b> and <b>confidence</b> in your
              OS setup.
            </p>
          </div>
        </a>
        <a href="/projects/book" class="project-card card-dark fade-up">
          <div class="project-card-bg"></div>
          <img
            src="/book.svg"
            alt="OpenShelf Logo"
            style="width: 60px; height: 60px;"
            loading="lazy"
            decoding="async"
          />
          <div class="project-card-content">
            <h3>OpenShelf</h3>
            <p>
              The privacy-focused community library. OpenSelf is a free and open
              source cataloging tool that empowers users to manage their digital
              collections with <b>clarity</b>, without the weight of proprietary
              trackers.
            </p>
          </div>
        </a>
        <a href="/projects/security" class="project-card card-dark fade-up">
          <div class="project-card-bg"></div>
          <img
            src="/security.svg"
            alt="ArcSecurity Logo"
            style="width: 60px; height: 60px;"
            loading="lazy"
            decoding="async"
          />
          <div class="project-card-content">
            <h3>ArcSecurity</h3>
            <p>
              Advanced OSINT and footprint analysis tools. ArcSecurity provides
              the tools for professionals to <b>build</b> a safer digital identity
              through transparent, community-vetted security research and automation.
            </p>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- MISSION SECTION (NEW FOR SEO) -->
  <section class="section mission-section">
    <div class="section-container">
      <div class="section-number fade-up">03</div>
      <div class="mission-content fade-up">
        <h2 class="section-title">The Open Source Mission</h2>
        <p class="section-desc" style="max-width: 800px;">
          For too long, the digital world has been divided into walled gardens
          and proprietary "black boxes." We believe that true technological
          progress is only possible when the foundation is open, transparent,
          and owned by everyone. This isn't just about code—it's about the
          <b>confidence</b> of knowing exactly what your devices are doing.
        </p>
        <p class="section-desc" style="max-width: 800px; margin-top: 1.5rem;">
          Our focus on the Linux and Android ecosystems stems from a simple core
          belief: users should have the <b>clarity</b> to audit, modify, and improve
          the tools they use every day. Whether we're developing kernel performance
          tuning scripts or building high-level package managers, we <b>build</b
          > everything with the community at the forefront.
        </p>
        <p class="section-desc" style="max-width: 800px; margin-top: 1.5rem;">
          When we <b>ship</b> a new project, we aren't just releasing software; we're
          contributing to a global coalition that values digital sovereignty over
          data harvesting. Join us as we continue to push the boundaries of what's
          possible in the open source space.
        </p>
      </div>
    </div>
  </section>

  <!-- CONTACT -->
  <section class="section contact-section" id="contact">
    <div class="section-container">
      <div class="section-number fade-up">04</div>
      <div class="contact-grid">
        <div class="contact-info fade-up">
          <h2 class="section-title">Questions?</h2>
          <p class="section-desc">
            Need support, want to ask questions, want to contribute, or just
            want to say hello? Reach out to us through any of these channels.
          </p>
          <div class="contact-channels">
            <a href="mailto:arcbase@tuta.io" class="contact-channel">
              <div class="channel-icon email">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"
                  ></path></svg
                >
              </div>
              <div class="channel-text">
                <h4>Email</h4>
                <p>arcbase@tuta.io</p>
              </div>
            </a>
            <a
              href="https://github.com/arcbasehq"
              target="_blank"
              rel="noopener"
              class="contact-channel"
            >
              <div class="channel-icon github">
                <svg viewBox="0 0 24 24"
                  ><path
                    d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"
                  ></path></svg
                >
              </div>
              <div class="channel-text">
                <h4>GitHub</h4>
                <p>Browse our repositories</p>
              </div>
            </a>
          </div>
        </div>
        <div class="contact-form-card fade-up">
          <form id="contactForm">
            <div class="form-group">
              <label for="email">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="you@example.com"
                required
              />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="What's this about?"
              />
            </div>
            <div class="form-group">
              <label for="message">Message</label>
              <textarea
                id="message"
                name="message"
                placeholder="Tell us what's on your mind..."
                required></textarea>
            </div>
            <button type="submit" class="form-submit">Send Message</button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <NewsletterSignup />

  <script>
    // Form handling (vanilla JS) with proper element type checks
    const contactFormEl = document.getElementById(
      "contactForm",
    ) as HTMLFormElement;
    if (contactFormEl) {
      contactFormEl.addEventListener("submit", async function (e) {
        e.preventDefault();
        const btn = contactFormEl.querySelector(
          ".form-submit",
        ) as HTMLButtonElement;

        // Get form data
        const formData = new FormData(contactFormEl);
        const email = formData.get("email") as string;
        const subject = formData.get("subject") as string;
        const message = formData.get("message") as string;

        if (!email || !message) return;

        // Visual feedback
        const originalText = btn.textContent;
        btn.disabled = true;
        btn.textContent = "Sending...";

        try {
          const { submitContactForm } = await import("../lib/actions");
          await submitContactForm({ email, subject, message });

          // Success state
          btn.textContent = "Message Sent!";
          btn.style.background = "linear-gradient(135deg, #059669, #047857)";
          contactFormEl.reset();

          setTimeout(function () {
            btn.textContent = originalText;
            btn.style.background = "";
            btn.disabled = false;
          }, 3000);
        } catch (error) {
          console.error("Form submission failed:", error);
          btn.textContent = "Error, try again";
          btn.style.background = "#dc2626"; // red-600

          setTimeout(function () {
            btn.textContent = originalText;
            btn.style.background = "";
            btn.disabled = false;
          }, 3000);
        }
      });
    }
  </script>
  <style>
    .principles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
      margin-top: 2rem;
    }

    .principle-card {
      background: rgba(255, 255, 255, 0.03);
      padding: 2.5rem;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
    }

    .principle-card:hover {
      border-color: var(--accent);
      background: rgba(255, 255, 255, 0.05);
      transform: translateY(-5px);
    }

    .principle-icon {
      width: 48px;
      height: 48px;
      background: rgba(59, 157, 255, 0.1);
      color: var(--accent);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }

    .principle-card h3 {
      font-size: 1.25rem;
      margin-bottom: 1rem;
      color: var(--text-primary);
    }

    .principle-card p {
      color: var(--text-secondary);
      line-height: 1.6;
      font-size: 0.95rem;
    }

    .mission-section {
      background: rgba(0, 0, 0, 0.2);
    }

    @media (max-width: 768px) {
      .principles-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</Layout>
