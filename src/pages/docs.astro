---
import Layout from "../layouts/Layout.astro";

const sidebarNav = [
    { title: "Getting Started", items: [
        { label: "Introduction", href: "#intro" },
        { label: "Installation", href: "#installation" },
        { label: "Quick Start", href: "#quickstart" },
    ]},
    { title: "Projects", items: [
        { label: "Sentinel", href: "#sentinel" },
        { label: "CryFox", href: "#cryfox" },
        { label: "ArcOSINT", href: "#osint" },
    ]},
    { title: "Resources", items: [
        { label: "Community", href: "#community" },
        { label: "Contributing", href: "#contributing" },
        { label: "Support", href: "#support" },
    ]},
];
---

<Layout
    title="Documentation — arcbase"
    description="Comprehensive documentation for all arcbase projects. Get started with Sentinel, CryFox, ArcOSINT, and more."
    keywords="documentation, docs, arcbase, sentinel, cryfox, guide, tutorial"
    activePage="docs"
>
    <div class="docs-layout">
        <aside class="docs-sidebar">
            <div class="docs-sidebar-header">
                <a href="/docs" class="docs-logo">
                    <span class="docs-logo-icon"> Docs</span>
                </a>
            </div>
            <nav class="docs-sidebar-nav">
                {sidebarNav.map((section) => (
                    <div class="docs-nav-section">
                        <h3 class="docs-nav-title">{section.title}</h3>
                        <ul class="docs-nav-list">
                            {section.items.map((item) => (
                                <li>
                                    <a href={item.href} class="docs-nav-link">{item.label}</a>
                                </li>
                            ))}
                        </ul>
                    </div>
                ))}
            </nav>
            <div class="docs-sidebar-footer">
                <a href="https://github.com/arcbasehq" target="_blank" rel="noopener" class="docs-sidebar-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
                    GitHub
                </a>
                <a href="/contact" class="docs-sidebar-link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                    Contact
                </a>
            </div>
        </aside>

        <main class="docs-main">
            <div class="docs-content">
                <section id="intro" class="docs-section">
                    <h1>Documentation</h1>
                    <p class="docs-lead">Welcome to the arcbase documentation. Everything you need to get started with our open source projects.</p>
                </section>

                <section id="installation" class="docs-section">
                    <h2>Installation</h2>
                    <p>Most arcbase tools are available through GitHub releases or package managers.</p>
                    <div class="docs-code">
                        <div class="docs-code-header">
                            <span>bash</span>
                            <button class="docs-copy-btn">Copy</button>
                        </div>
                        <pre><code>{`# Clone any arcbase project
git clone https://github.com/arcbasehq/{project}.git
cd {project}

# Follow project-specific setup
cat README.md`}</code></pre>
                    </div>
                </section>

                <section id="quickstart" class="docs-section">
                    <h2>Quick Start</h2>
                    <p>Get up and running in minutes with any of our projects.</p>
                    <div class="docs-steps">
                        <div class="docs-step">
                            <span class="docs-step-num">01</span>
                            <div>
                                <h3>Choose a Project</h3>
                                <p>Browse our projects and find one that fits your needs.</p>
                            </div>
                        </div>
                        <div class="docs-step">
                            <span class="docs-step-num">02</span>
                            <div>
                                <h3>Clone & Setup</h3>
                                <p>Clone the repository and follow the setup instructions.</p>
                            </div>
                        </div>
                        <div class="docs-step">
                            <span class="docs-step-num">03</span>
                            <div>
                                <h3>Start Building</h3>
                                <p>Run the project locally and start contributing.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section id="sentinel" class="docs-section">
                    <h2>Sentinel</h2>
                    <p>Open source security for the modern web. Sentinel provides automated vulnerability scanning, dependency auditing, and security monitoring.</p>
                    
                    <h3>Installation</h3>
                    <div class="docs-code">
                        <div class="docs-code-header"><span>bash</span></div>
                        <pre><code>npm install -g @arcbase/sentinel</code></pre>
                    </div>

                    <h3>Usage</h3>
                    <div class="docs-code">
                        <div class="docs-code-header"><span>bash</span></div>
                        <pre><code># Run a security scan
sentinel scan

# Audit dependencies
sentinel audit

# Generate report
sentinel report --format html</code></pre>
                    </div>
                </section>

                <section id="cryfox" class="docs-section">
                    <h2>CryFox</h2>
                    <p>A private, secure, and fast Firefox fork. Built for users who value privacy and performance.</p>
                    
                    <h3>Installation</h3>
                    <div class="docs-code">
                        <div class="docs-code-header"><span>bash</span></div>
                        <pre><code># Download from GitHub releases
curl -L -o cryfox.tar.gz https://github.com/arcbasehq/cryfox/releases/latest
tar -xzf cryfox.tar.gz</code></pre>
                    </div>

                    <h3>Features</h3>
                    <ul class="docs-feature-list">
                        <li>Zero telemetry — your data stays on your device</li>
                        <li>Built-in tracker blocking</li>
                        <li>Fingerprint hardening</li>
                        <li>Performance optimized</li>
                        <li>100% open source</li>
                    </ul>
                </section>

                <section id="osint" class="docs-section">
                    <h2>ArcOSINT</h2>
                    <p>Advanced OSINT in a secure, modern terminal UI. Email, username, IP, domain, and phone intelligence.</p>
                    
                    <h3>Installation</h3>
                    <div class="docs-code">
                        <div class="docs-code-header"><span>bash</span></div>
                        <pre><code>pip install arcbase-osint</code></pre>
                    </div>
                </section>

                <section id="community" class="docs-section">
                    <h2>Community</h2>
                    <p>Join thousands of developers and users building the future of open source.</p>
                    
                    <div class="docs-cards-inline">
                        <a href="https://github.com/arcbasehq" target="_blank" rel="noopener" class="docs-resource-card">
                            <h3>GitHub</h3>
                            <p>Browse source code, file issues, and contribute.</p>
                        </a>
                        <a href="/contact" class="docs-resource-card">
                            <h3>Contact</h3>
                            <p>Questions, feedback, or partnerships.</p>
                        </a>
                        <a href="/blog" class="docs-resource-card">
                            <h3>Blog</h3>
                            <p>Latest news and updates from the team.</p>
                        </a>
                    </div>
                </section>

                <section id="contributing" class="docs-section">
                    <h2>Contributing</h2>
                    <p>We welcome contributions of all kinds. Here's how you can help.</p>
                    
                    <div class="docs-code">
                        <div class="docs-code-header"><span>bash</span></div>
                        <pre><code>{`# Fork the repo
git fork https://github.com/arcbasehq/{project}

# Create a feature branch
git checkout -b feature/my-feature

# Make changes and commit
git commit -m "Add my feature"

# Push and create PR
git push origin feature/my-feature`}</code></pre>
                    </div>
                </section>

                <section id="support" class="docs-section">
                    <h2>Support</h2>
                    <p>Need help? We're here for you.</p>
                    <ul class="docs-feature-list">
                        <li><strong>GitHub Issues</strong> — Report bugs and request features</li>
                        <li><strong>Email</strong> — arcbase@tuta.io</li>
                        <li><strong>Community</strong> — Join our growing community</li>
                    </ul>
                </section>
            </div>
        </main>
    </div>
</Layout>

<style>
    .docs-layout {
        display: flex;
        min-height: 100vh;
        padding-top: 68px;
    }

    .docs-sidebar {
        width: 260px;
        position: fixed;
        top: 68px;
        left: 0;
        bottom: 0;
        background: var(--surface);
        border-right: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        overflow-y: auto;
        background-image: 
            linear-gradient(rgba(0, 0, 0, 0.015) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0, 0, 0, 0.015) 1px, transparent 1px);
        background-size: 20px 20px;
    }

    .docs-sidebar-header {
        padding: 20px;
        border-bottom: 1px solid var(--border);
    }

    .docs-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        color: var(--text-primary);
    }

    .docs-logo-icon {
        font-size: 0.875rem;
        color: var(--text-secondary);
    }

    .docs-sidebar-nav {
        flex: 1;
        padding: 20px 12px;
    }

    .docs-nav-section {
        margin-bottom: 24px;
    }

    .docs-nav-title {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-tertiary);
        padding: 0 12px;
        margin-bottom: 10px;
    }

    .docs-nav-list {
        list-style: none;
    }

    .docs-nav-link {
        display: block;
        padding: 8px 12px;
        font-size: 0.875rem;
        color: var(--text-secondary);
        border-radius: var(--radius);
        transition: all 0.15s ease;
    }

    .docs-nav-link:hover {
        color: var(--text-primary);
        background: var(--bg-secondary);
    }

    .docs-sidebar-footer {
        padding: 16px 20px;
        border-top: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .docs-sidebar-link {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.8125rem;
        color: var(--text-tertiary);
    }

    .docs-sidebar-link:hover {
        color: var(--text-primary);
    }

    .docs-main {
        flex: 1;
        margin-left: 260px;
        min-width: 0;
    }

    .docs-content {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 48px 80px;
    }

    .docs-section {
        margin-bottom: 48px;
        scroll-margin-top: 80px;
    }

    .docs-section h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 16px;
    }

    .docs-lead {
        font-size: 1.125rem;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .docs-section h2 {
        font-size: 1.75rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 16px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
    }

    .docs-section h2:first-of-type {
        border-top: none;
        padding-top: 0;
    }

    .docs-section h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin: 24px 0 12px;
    }

    .docs-section p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 16px;
    }

    .docs-code {
        background: #1a1a1a;
        border-radius: var(--radius-md);
        overflow: hidden;
        margin: 16px 0 24px;
    }

    .docs-code-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 8px 16px;
        background: rgba(255, 255, 255, 0.05);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .docs-code-header span {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.5);
    }

    .docs-copy-btn {
        background: rgba(255, 255, 255, 0.1);
        border: none;
        color: rgba(255, 255, 255, 0.6);
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 0.6875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s ease;
    }

    .docs-copy-btn:hover {
        background: rgba(255, 255, 255, 0.2);
        color: #fff;
    }

    .docs-code pre {
        padding: 16px;
        margin: 0;
        overflow-x: auto;
    }

    .docs-code code {
        font-family: "SF Mono", "Fira Code", monospace;
        font-size: 0.8125rem;
        line-height: 1.7;
        color: #e2e8f0;
    }

    .docs-steps {
        display: flex;
        flex-direction: column;
        gap: 20px;
        margin: 24px 0;
    }

    .docs-step {
        display: flex;
        gap: 16px;
        padding: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }

    .docs-step-num {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--accent-light);
        color: var(--accent);
        font-size: 0.75rem;
        font-weight: 700;
        border-radius: 8px;
        flex-shrink: 0;
    }

    .docs-step h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
    }

    .docs-step p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        margin: 0;
    }

    .docs-feature-list {
        list-style: none;
        margin: 16px 0;
    }

    .docs-feature-list li {
        padding: 10px 0;
        font-size: 0.9375rem;
        color: var(--text-secondary);
        border-bottom: 1px solid var(--border);
    }

    .docs-feature-list li:last-child {
        border-bottom: none;
    }

    .docs-feature-list strong {
        color: var(--text-primary);
    }

    .docs-cards-inline {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin: 24px 0;
    }

    .docs-resource-card {
        padding: 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        display: block;
        transition: all 0.2s ease;
    }

    .docs-resource-card:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-md);
    }

    .docs-resource-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 4px;
        margin-top: 0;
        padding: 0;
        border: none;
    }

    .docs-resource-card p {
        font-size: 0.8125rem;
        color: var(--text-tertiary);
        margin: 0;
    }

    @media (max-width: 1024px) {
        .docs-sidebar {
            display: none;
        }
        .docs-main {
            margin-left: 0;
        }
        .docs-content {
            padding: 32px 24px;
        }
    }

    @media (max-width: 640px) {
        .docs-cards-inline {
            grid-template-columns: 1fr;
        }
        .docs-section h1 {
            font-size: 2rem;
        }
    }
</style>

<script>
    document.querySelectorAll('.docs-copy-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const code = btn.closest('.docs-code')?.querySelector('code')?.textContent || '';
            navigator.clipboard.writeText(code).then(() => {
                btn.textContent = 'Copied!';
                setTimeout(() => btn.textContent = 'Copy', 2000);
            });
        });
    });
</script>