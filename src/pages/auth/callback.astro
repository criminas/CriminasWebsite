---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Signing In..."
    description="Completing your sign-in"
    activePage=""
>
    <section class="callback-page">
        <div class="callback-card">
            <div class="spinner"></div>
            <h2>Signing you in...</h2>
            <p>Please wait while we complete your authentication.</p>
        </div>
    </section>
</Layout>

<script>
    import { supabase } from "../../lib/supabase";

    async function handleCallback() {
        // Supabase client automatically processes the access_token from the URL hash
        // We just need to wait a moment to make sure the session is established.
        
        try {
            const { data, error } = await supabase.auth.getSession();
            
            // if we have a session, redirect to the dashboard
            if (data.session) {
                window.location.href = "/dashboard";
                return;
            }

            // On some OAuth setups like Google, Supabase might need to fetch the user 
            // after processing the URL. Let's wait up to 2 seconds polling for the user.
            for (let i = 0; i < 20; i++) {
                const { data: userResp } = await supabase.auth.getUser();
                if (userResp.user) {
                    window.location.href = "/dashboard";
                    return;
                }
                await new Promise(r => setTimeout(r, 100)); // wait 100ms
            }

            // If we still don't have a user, Auth failed or invalid token.
            console.error("No valid session found during OAuth callback.");
            window.location.href = "/login";
        } catch (error) {
            console.error("OAuth callback error:", error);
            window.location.href = "/login";
        }
    }

    handleCallback();
</script>

<style>
    .callback-page {
        min-height: calc(100vh - 56px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 80px 24px 48px;
        background: var(--bg-primary);
    }

    .callback-card {
        text-align: center;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 64px 48px;
        max-width: 420px;
        width: 100%;
    }

    .callback-card h2 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .callback-card p {
        color: var(--text-secondary);
        font-size: 0.9375rem;
    }

    .spinner {
        width: 48px;
        height: 48px;
        border: 3px solid var(--border);
        border-top-color: var(--accent);
        border-radius: 50%;
        margin: 0 auto 24px;
        animation: spin 0.8s linear infinite;
    }

    @keyframes spin {
        to { transform: rotate(360deg); }
    }
</style>
