---
import Layout from "../layouts/Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";
---

<Layout
    title="About arcbase — Our Mission, Story & Team"
    description="Learn about arcbase, the open source organization empowering everyone to change their world. Discover our mission, values, team, and the story behind our movement."
    keywords="arcbase about, open source mission, arcbase team, linux community, open source organization, arcbase values"
    activePage="about"
    ogType="article"
>
    <section class="page-hero">
        <div class="page-hero-content">
            <h1>About <span class="highlight">arcbase</span></h1>
            <p>
                We're a team, a movement, and a community — united by the
                mission to bring open source software to the masses.
            </p>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <div class="about-grid">
                <div class="fade-up">
                    <div class="section-number">Mission</div>
                    <h2 class="section-title">Our Mission</h2>
                    <p class="section-desc">
                        At arcbase, we believe that open source software is the
                        future — not just for developers, but for everyone. Our
                        mission is to make that future accessible, approachable,
                        and empowering.
                    </p>
                    <p class="section-desc" style="margin-top: 16px;">
                        We build software, products, communities, and coalitions
                        that bridge the gap between the open source world and
                        the everyday person. From operating systems to developer
                        tools, everything we create is designed to be intuitive,
                        beautiful, and free.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="about-card">
                        <div class="about-stats">
                            <div class="stat-item">
                                <div class="stat-number">100%</div>
                                <div class="stat-label">Open Source</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">∞</div>
                                <div class="stat-label">Possibilities</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">24/7</div>
                                <div class="stat-label">Community</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">0</div>
                                <div class="stat-label">Barriers</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <div class="section-number fade-up">Values</div>
            <h2 class="section-title fade-up">Our Values</h2>
            <p class="section-desc fade-up" style="margin-bottom: 32px;">
                The principles that guide everything we build and every decision
                we make.
            </p>

            <div class="values-grid">
                <div class="value-card fade-up">
                    <h3>Openness First</h3>
                    <p>
                        Everything we build is open source. Transparency isn't
                        just a feature — it's our foundation. We believe in
                        sharing knowledge and code freely.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <h3>Community Driven</h3>
                    <p>
                        Our community shapes what we build. Contributors, users,
                        and advocates all have a voice in our direction.
                        Together, we build better software.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <h3>Design Matters</h3>
                    <p>
                        Open source shouldn't mean ugly. We're obsessed with
                        design, usability, and polish. Great software deserves a
                        great experience.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <h3>Innovation Forward</h3>
                    <p>
                        We don't settle for the status quo. We push boundaries,
                        challenge conventions, and build things that haven't
                        existed before.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <div class="section-number fade-up">Journey</div>
            <h2 class="section-title fade-up">Our Journey</h2>
            <p class="section-desc fade-up">
                From a small idea to a growing movement.
            </p>

            <div class="timeline">
                <div class="timeline-item fade-up">
                    <div class="year">2025</div>
                    <h3>The Spark</h3>
                    <p>
                        arcbase was born from a simple idea: open source
                        software should be for everyone, not just developers. A
                        small team came together with a shared vision.
                    </p>
                </div>
                <div class="timeline-item fade-up">
                    <div class="year">2026</div>
                    <h3>First Projects Launch</h3>
                    <p>
                        Sentinel and CrimiRepo launched to the public. The
                        community grew rapidly as developers and everyday users
                        joined forces.
                    </p>
                </div>
                <div class="timeline-item fade-up">
                    <div class="year">2026</div>
                    <h3>Growing the Ecosystem</h3>
                    <p>
                        With Forge, Nexus, CrimiRepo, and Sentinel added to the
                        lineup, arcbase now offers a complete ecosystem of open
                        source tools. The movement continues.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block" style="text-align: center;">
        <div class="section-container fade-up">
            <h2 class="section-title">Ready to join us?</h2>
            <p class="section-desc" style="margin: 0 auto 24px;">
                Whether you're a developer, designer, writer, or just passionate
                about open source — there's a place for you at arcbase.
            </p>
            <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
                <a href="/contact" class="btn-primary">Get in Touch</a>
                <a href="https://github.com/arcbasehq" target="_blank" rel="noopener" class="btn-secondary">View GitHub</a>
            </div>
        </div>
    </section>

    <NewsletterSignup />

    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "AboutPage",
            name: "About arcbase",
            description: "Learn about arcbase, the open source organization empowering everyone to change their world.",
            mainEntity: {
                "@type": "Organization",
                name: "arcbase",
                description: "Empowering everyone to change their world, by bringing open source software to the masses.",
            },
        })}
    />
</Layout>