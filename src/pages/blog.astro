---
import Layout from "../layouts/Layout.astro";
import NewsletterSignup from "../components/NewsletterSignup.astro";

const posts = [
    {
        title: "Introducing arcbase: Our Mission to Democratize Open Source",
        date: "March 5, 2026",
        excerpt: "Today we're publicly sharing our vision: to bring open source software to the masses. Here's why we started arcbase, what we're building, and how you can be part of the movement.",
        tag: "Announcement",
        slug: "#",
        featured: true,
    },
    {
        title: "ArcOS 1.0 Beta: A Cleaner, Faster Windows Experience",
        date: "February 28, 2026",
        excerpt: "ArcOS strips away the bloat from Windows 11, giving you a privacy-focused, performance-optimized OS designed for power users and enthusiasts.",
        tag: "Release",
        slug: "/projects/os",
    },
    {
        title: "How Sentinel Keeps Your Code Safe — Automatically",
        date: "February 14, 2026",
        excerpt: "Dependency vulnerabilities are one of the biggest threats to modern apps. Learn how Sentinel scans, audits, and monitors your projects so you don't have to.",
        tag: "Guide",
        slug: "/projects/sentinel",
    },
    {
        title: "Contributor Spotlight: Building Arc Manager Together",
        date: "January 30, 2026",
        excerpt: "Meet the contributors behind Arc Manager — the unified Linux package manager frontend. See how open source collaboration is shaping the future of package management.",
        tag: "Community",
        slug: "/projects/manager",
    },
    {
        title: "2026 Roadmap: What's Next for arcbase",
        date: "January 15, 2026",
        excerpt: "From Arcbase Learning to Analysis AI, here's a look at everything we're building this year and how our community is driving the direction.",
        tag: "Roadmap",
        slug: "/about",
    },
];
---

<Layout
    title="Blog — News, Updates & Guides from arcbase"
    description="Read the latest news, project updates, tutorials, and community stories from the arcbase open source movement."
    keywords="arcbase blog, open source news, developer tutorials, arcbase updates, community stories"
    activePage="blog"
    ogType="blog"
>
    <section class="page-hero">
        <div class="page-hero-content">
            <h1><span class="highlight">Blog</span></h1>
            <p>News, updates, guides, and stories from the arcbase community.</p>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <a href={posts[0].slug} class="blog-featured-card fade-up">
                <div class="blog-card-meta">
                    <span class="blog-tag">{posts[0].tag}</span>
                    <span class="blog-date">{posts[0].date}</span>
                </div>
                <h2>{posts[0].title}</h2>
                <p>{posts[0].excerpt}</p>
                <span class="about-link">Read article →</span>
            </a>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <h2 class="section-title fade-up">Latest Posts</h2>
            <div class="blog-grid">
                {posts.slice(1).map((post) => (
                    <a href={post.slug} class="blog-card fade-up">
                        <div class="blog-card-meta">
                            <span class="blog-tag">{post.tag}</span>
                            <span class="blog-date">{post.date}</span>
                        </div>
                        <h3>{post.title}</h3>
                        <p>{post.excerpt}</p>
                        <span class="about-link" style="margin-top: auto;">Read more →</span>
                    </a>
                ))}
            </div>
        </div>
    </section>

    <NewsletterSignup />

    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "Blog",
            name: "arcbase Blog",
            description: "News, updates, guides, and community stories from arcbase.",
            url: "https://arcbase.one/blog",
            publisher: { "@type": "Organization", name: "arcbase", url: "https://arcbase.one" },
        })}
    />
</Layout>

<style>
    .blog-featured-card {
        display: block;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px;
        transition: all 0.2s ease;
    }

    .blog-featured-card:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-md);
    }

    .blog-featured-card h2 {
        font-size: clamp(1.5rem, 3vw, 2rem);
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 12px;
    }

    .blog-featured-card p {
        font-size: 1rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin-bottom: 16px;
    }

    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 24px;
    }

    .blog-card {
        display: flex;
        flex-direction: column;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 24px;
        transition: all 0.2s ease;
    }

    .blog-card:hover {
        border-color: var(--border-strong);
        box-shadow: var(--shadow-md);
    }

    .blog-card h3 {
        font-size: 1.125rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .blog-card p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .blog-card-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
    }

    .blog-tag {
        font-size: 0.6875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 4px 10px;
        border-radius: 100px;
        background: var(--accent-light);
        color: var(--accent);
    }

    .blog-date {
        font-size: 0.8125rem;
        color: var(--text-tertiary);
    }

    @media (max-width: 768px) {
        .blog-featured-card { padding: 24px; }
        .blog-grid { grid-template-columns: 1fr; }
    }
</style>