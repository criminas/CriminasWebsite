---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="ArcOSINT — Advanced OSINT Framework"
    description="ArcOSINT is a secure, terminal-first OSINT framework for ethical security research. Email, username, IP, domain, phone, and metadata intelligence in one modern TUI."
    keywords="ArcOSINT, OSINT framework, open source intelligence, security research, terminal UI, Criminas, Arcbase"
    activePage="projects"
    ogType="article"
>
    <!-- PAGE HERO -->
    <section class="page-hero">
        <div class="hero-glow glow-1"></div>
        <div class="hero-glow glow-2"></div>
        <div class="page-hero-content fade-up">
            <h1><span class="highlight">ArcOSINT</span></h1>
            <p>Advanced OSINT in a secure, modern terminal UI.</p>
        </div>
    </section>

    <!-- OVERVIEW -->
    <section class="content-block">
        <div class="content-container">
            <div class="content-grid">
                <div class="fade-up">
                    <div class="section-number">00</div>
                    <h2 class="section-title">What is ArcOSINT?</h2>
                    <p class="section-desc">
                        ArcOSINT is a comprehensive, terminal-based OSINT
                        framework built for ethical security research. It brings
                        powerful investigation modules together with a clean,
                        intuitive TUI for fast, focused analysis.
                    </p>
                    <p class="section-desc" style="margin-top: 1rem;">
                        From email and username intelligence to IP, domain,
                        phone, and metadata investigations, ArcOSINT keeps
                        everything local, privacy-aware, and easy to export.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="project-detail-card">
                        <div
                            class="project-detail-header"
                            style="background: linear-gradient(135deg, #0a0a1a, #1a1a3e);"
                        >
                            <span
                                class="project-tag"
                                style="color: #ef4444; background: rgba(239, 68, 68, 0.1);"
                                >OSINT</span
                            >
                            <h3 style="color: #fff;">ArcOSINT</h3>
                        </div>
                        <div class="project-detail-body">
                            <p style="margin-top: 1.5rem;">
                                Advanced OSINT with a secure, modern TUI.
                            </p>
                            <ul class="project-features">
                                <li>Email intelligence and breach checks</li>
                                <li>Username enumeration across platforms</li>
                                <li>IP and ASN intelligence</li>
                                <li>Domain and DNS analysis</li>
                                <li>Metadata extraction and hashing</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="content-block alt">
        <div class="content-container">
            <div class="section-number fade-up">01</div>
            <h2 class="section-title fade-up">Core Capabilities</h2>
            <p class="section-desc fade-up" style="margin-bottom: 3rem;">
                Comprehensive OSINT coverage with real-time results.
            </p>

            <div class="values-grid">
                <div class="value-card fade-up">
                    <div class="value-icon purple">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><circle cx="11" cy="11" r="8"></circle><line
                                x1="21"
                                y1="21"
                                x2="16.65"
                                y2="16.65"></line></svg
                        >
                    </div>
                    <h3>Email Intelligence</h3>
                    <p>
                        Validation, deliverability checks, breach detection,
                        SPF/DMARC/MX analysis, and reputation scoring.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon blue">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <h3>Username Enumeration</h3>
                    <p>
                        Search across 50+ platforms with concurrent lookups and
                        profile verification.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon green">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"
                            ></path><rect
                                x="8"
                                y="2"
                                width="8"
                                height="4"
                                rx="1"
                                ry="1"></rect></svg
                        >
                    </div>
                    <h3>IP Address Intelligence</h3>
                    <p>
                        City-level geolocation, ASN details, threat scoring,
                        reverse DNS, and public/private classification.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon pink">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                            ></path><path
                                d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                            ></path></svg
                        >
                    </div>
                    <h3>Domain Analysis</h3>
                    <p>
                        DNS enumeration, WHOIS, SSL inspection, subdomain
                        discovery, and security header analysis.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section
        class="content-block"
        style="text-align: center; padding-bottom: 6rem;"
    >
        <div class="content-container fade-up">
            <h2 class="section-title">Investigate with confidence</h2>
            <p class="section-desc" style="margin: 0 auto 2rem;">
                ArcOSINT is open source and built for ethical research. Explore
                the codebase and contribute new modules.
            </p>
            <div
                style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
            >
                <a
                    href="https://github.com/arcbasehq/ArcSecurity"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">View on GitHub</a
                >
                <a
                    href="/projects"
                    class="btn-secondary"
                    >All Projects</a
                >
            </div>
        </div>
    </section>
    <!-- Structured Data for ArcOSINT -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "ArcOSINT",
            applicationCategory: "SecurityApplication",
            operatingSystem: "Any",
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "USD",
            },
            description:
                "ArcOSINT is a terminal-based OSINT framework for ethical security research with email, username, IP, domain, phone, and metadata intelligence.",
            featureList: [
                "Email intelligence and breach checks",
                "Username enumeration",
                "IP and domain intelligence",
            ],
            author: {
                "@type": "Organization",
                name: "Criminas",
            },
        })}
    />
</Layout>