---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="ArcOS — Optimized Windows for Enthusiasts"
    description="ArcOS is a lean, privacy-first build of Windows engineered for raw speed. No bloat. No telemetry. Just performance."
    keywords="ArcOS, optimized Windows, Windows performance, privacy, bloatware removal, Criminas, fast Windows"
    activePage="projects"
    ogType="article"
>
    <!-- PAGE HERO -->
    <section class="page-hero">
        <div class="hero-glow glow-1"></div>
        <div class="hero-glow glow-2"></div>
        <div class="page-hero-content fade-up" style="display: flex; align-items: center; gap: 3rem; text-align: left; max-width: 1100px; width: 100%;">
            <!-- Left: logo + tagline -->
            <div style="flex: 0 0 auto;">
                <img src="/arctext.png" alt="ArcOS" style="width: 200px; height: auto; display: block; margin-bottom: 1rem;"/>
                <p style="margin: 0; font-size: 1.1rem; opacity: 0.7;">Optimized Windows. Designed for enthusiasts.</p>
            </div>
            <!-- Right: preview -->
            <div class="arc-preview" style="flex: 1 1 0; min-width: 0; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,0.1); box-shadow: 0 24px 60px rgba(0,0,0,0.5);">
                <img src="/wallpaper.png" alt="ArcOS Preview" style="width: 100%; height: auto; display: block;"/>
            </div>
        </div>
    </section>

    <!-- OVERVIEW -->
    <section class="content-block">
        <div class="content-container">
            <div class="content-grid">
                <div class="fade-up">
                    <div class="section-number">00</div>
                    <h2 class="section-title">What is ArcOS?</h2>
                    <p class="section-desc">
                        ArcOS is a modified version of Windows stripped back to
                        what matters and optimized for raw speed. It removes
                        telemetry, disables unnecessary background services, and
                        applies system-level performance tweaks — while staying
                        fully compatible with your existing software.
                    </p>
                    <p class="section-desc" style="margin-top: 1rem;">
                        ArcOS is not a standalone operating system. It's a set
                        of scripts, policies, and configurations applied on top
                        of a standard Windows installation. You keep full
                        Windows compatibility and can revert at any time.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="project-detail-card">
                        <div
                            class="project-detail-header"
                            style="background: linear-gradient(135deg, #020d1f, #0f2a5c);"
                        >
                            <span
                                class="project-tag"
                                style="color: #2563eb; background: rgba(37, 99, 235, 0.1);"
                                >Windows</span
                            >
                            <h3 style="color: #fff;">ArcOS</h3>
                        </div>
                        <div class="project-detail-body">
                            <p style="margin-top: 1.5rem;">
                                Lean, fast, private Windows — without the bloat.
                            </p>
                            <ul class="project-features">
                                <li>Removes 35+ unnecessary background services</li>
                                <li>Disables Windows telemetry and tracking</li>
                                <li>Up to 2.7× faster cold boot times</li>
                                <li>Significantly lower idle CPU and RAM usage</li>
                                <li>Fully reversible — revert any time</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="content-block alt">
        <div class="content-container">
            <div class="section-number fade-up">01</div>
            <h2 class="section-title fade-up">Core Features</h2>
            <p class="section-desc fade-up" style="margin-bottom: 3rem;">
                Lean, private, and fast — without sacrificing compatibility.
            </p>

            <div class="values-grid">
                <div class="value-card fade-up">
                    <div class="value-icon blue">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                            ></polygon></svg
                        >
                    </div>
                    <h3>Raw Performance</h3>
                    <p>
                        Disables 35+ background services and applies power plan
                        tuning to free up CPU and RAM — resulting in faster boot
                        times, lower latency, and a snappier feel.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon purple">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <h3>Privacy by Default</h3>
                    <p>
                        Disables Windows telemetry, blocks Microsoft advertising
                        IDs, and removes invasive background data collection —
                        making Windows genuinely private.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon green">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M14 9V5a3 3 0 0 0-3-3l-4 9v11h11.28a2 2 0 0 0 2-1.7l1.38-9a2 2 0 0 0-2-2.3zM7 22H4a2 2 0 0 1-2-2v-7a2 2 0 0 1 2-2h3"
                            ></path></svg
                        >
                    </div>
                    <h3>Streamlined Usability</h3>
                    <p>
                        Removes pre-installed bloatware, disables ads in the
                        Start menu, and cleans up the interface for a leaner,
                        faster daily experience right out of the box.
                    </p>
                </div>
                <div class="value-card fade-up">
                    <div class="value-icon pink">
                        <svg
                            viewBox="0 0 24 24"
                            width="20"
                            height="20"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><polyline points="23 4 23 8 19 8"></polyline><polyline
                                points="1 20 1 16 5 16"></polyline><path
                                d="M3.51 9a9 9 0 0 1 14.85-3.36L23 8M1 16l4.64 4.36A9 9 0 0 0 20.49 15"
                            ></path></svg
                        >
                    </div>
                    <h3>Stays Updated</h3>
                    <p>
                        Security patches and cumulative updates are applied
                        automatically. Feature updates are held back to preserve
                        your performance optimizations.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section
        class="content-block"
        style="text-align: center; padding-bottom: 6rem;"
    >
        <div class="content-container fade-up">
            <h2 class="section-title">Get ArcOS</h2>
            <p class="section-desc" style="margin: 0 auto 2rem;">
                ArcOS is open source and free. Download the latest release or
                explore the source code on GitHub.
            </p>
            <div
                style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;"
            >
                <a
                    href="https://github.com/criminas/arcos/releases"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">Download</a
                >
                <a
                    href="https://os.arcbase.one"
                    target="_blank"
                    rel="noopener"
                    class="btn-secondary">Visit site</a
                >
            </div>
        </div>
    </section>

    <!-- Structured Data for ArcOS -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "ArcOS",
            applicationCategory: "UtilitiesApplication",
            operatingSystem: "Windows",
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "USD",
            },
            description:
                "ArcOS is a lean, privacy-first build of Windows engineered for raw speed. Removes telemetry, bloatware, and unnecessary background services.",
            featureList: [
                "Removes 35+ unnecessary background services",
                "Disables Windows telemetry and tracking",
                "Up to 2.7x faster cold boot times",
                "Significantly lower idle CPU and RAM usage",
            ],
            author: {
                "@type": "Organization",
                name: "Criminas",
            },
        })}
    />
</Layout>