---
import Layout from "../../layouts/Layout.astro";
---

<Layout
    title="Arc Manager — Unified Linux Package Management"
    description="Arc Manager is a unified cross-distribution Linux package manager frontend. Standardize pacman, apt, dnf, and AUR under one consistent CLI."
    keywords="Arc Manager, Linux package manager, pacman frontend, apt frontend, dnf frontend, AUR helper, open source, arcbase"
    activePage="projects"
    ogType="article"
>
    <!-- PAGE HERO -->
    <section class="page-hero">
        <div class="hero-glow glow-1"></div>
        <div class="hero-glow glow-2"></div>
        <div class="page-hero-content fade-up">
            <h1><span class="highlight">Arc Manager</span></h1>
            <p>Unified Linux package management across distributions.</p>
            <br>
            <a href="https://github.com/arcbasehq/ArcManager/releases/download/Release/arc-1.1.0.tar.gz">
                <button class="btn-primary">
                    Download Now
                </button>
            </a>
        </div>
    </section>

    <!-- OVERVIEW -->
    <section class="content-block">
        <div class="content-container">
            <div class="content-grid">
                <div class="fade-up">
                    <div class="section-number">00</div>
                    <h2 class="section-title">What is Arc Manager?</h2>
                    <p class="section-desc">
                        Arc Manager is a unified cross-distribution package
                        management frontend for Linux. It standardizes access to
                        pacman, apt, dnf, and AUR helpers under a single,
                        consistent command-line interface.
                    </p>
                    <p class="section-desc" style="margin-top: 1rem;">
                        It does not replace your system’s package manager.
                        Instead, it provides a clean, predictable interface
                        across distributions while safely delegating to the
                        native backend.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="project-detail-card">
                        <div
                            class="project-detail-header"
                            style="background: linear-gradient(135deg, #111827, #1f2937);"
                        >
                            <span
                                class="project-tag"
                                style="color: #22c55e; background: rgba(34, 197, 94, 0.1);"
                                >Developer Tool</span
                            >
                            <h3 style="color: #fff;">Arc Manager</h3>
                        </div>
                        <div class="project-detail-body">
                            <p style="margin-top: 1.5rem;">
                                One CLI for package management across major
                                Linux distributions.
                            </p>
                            <ul class="project-features">
                                <li>Cross-distribution support</li>
                                <li>Automatic backend detection</li>
                                <li>AUR fallback (Arch-based systems)</li>
                                <li>Dry-run mode</li>
                                <li>Non-interactive mode</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- FEATURES -->
    <section class="content-block alt">
        <div class="content-container">
            <div class="section-number fade-up">01</div>
            <h2 class="section-title fade-up">Core Features</h2>
            <p class="section-desc fade-up" style="margin-bottom: 3rem;">
                Simplicity without sacrificing control.
            </p>

            <div class="values-grid">
                <div class="value-card fade-up">
                    <div class="value-icon purple">
                        <svg viewBox="0 0 24 24" width="20" height="20"
                             fill="none" stroke="currentColor" stroke-width="2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12h18"></path>
                            <path d="M12 3v18"></path>
                        </svg>
                    </div>
                    <h3>Unified Interface</h3>
                    <p>
                        Use the same commands across Arch, Debian, and Fedora
                        systems without relearning different package tools.
                    </p>
                </div>

                <div class="value-card fade-up">
                    <div class="value-icon blue">
                        <svg viewBox="0 0 24 24" width="20" height="20"
                             fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 20V10"></path>
                            <path d="M18 20V4"></path>
                            <path d="M6 20v-6"></path>
                        </svg>
                    </div>
                    <h3>Smart Backend Detection</h3>
                    <p>
                        Automatically detects your distribution and selects the
                        appropriate package manager.
                    </p>
                </div>

                <div class="value-card fade-up">
                    <div class="value-icon green">
                        <svg viewBox="0 0 24 24" width="20" height="20"
                             fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 2l7 4v6c0 5-7 10-7 10S5 17 5 12V6l7-4z"></path>
                        </svg>
                    </div>
                    <h3>AUR Support</h3>
                    <p>
                        On Arch-based systems, automatically falls back to AUR
                        helpers like yay or paru when packages aren’t found in
                        official repositories.
                    </p>
                </div>

                <div class="value-card fade-up">
                    <div class="value-icon pink">
                        <svg viewBox="0 0 24 24" width="20" height="20"
                             fill="none" stroke="currentColor" stroke-width="2">
                            <circle cx="12" cy="12" r="10"></circle>
                            <path d="M12 6v6l4 2"></path>
                        </svg>
                    </div>
                    <h3>Safe Execution</h3>
                    <p>
                        Delegates directly to native package managers without
                        modifying system behavior or mixing ecosystems.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA -->
    <section class="content-block"
             style="text-align: center; padding-bottom: 6rem;">
        <div class="content-container fade-up">
            <h2 class="section-title">Simplify your workflow</h2>
            <p class="section-desc" style="margin: 0 auto 2rem;">
                Arc Manager is open source and community-driven.
                Contribute, improve, and help standardize Linux tooling.
            </p>
            <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                <a href="https://github.com/arcbasehq/arcmanager"
                   target="_blank"
                   rel="noopener"
                   class="btn-primary">View on GitHub</a>
                <a href="/projects"
                   class="btn-secondary">All Projects</a>
            </div>
        </div>
    </section>

    <!-- Structured Data -->
    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "Arc Manager",
            applicationCategory: "DeveloperApplication",
            operatingSystem: "Linux",
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "USD"
            },
            description:
                "Arc Manager is a unified Linux package manager frontend supporting pacman, apt, dnf, and AUR helpers under one consistent CLI.",
            featureList: [
                "Cross-distribution support",
                "Automatic backend detection",
                "AUR fallback support",
                "Dry-run mode"
            ],
            author: {
                "@type": "Organization",
                name: "arcbase"
            }
        })}
    />
</Layout>