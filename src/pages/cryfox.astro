---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="CryFox — A Private, Secure, and Fast Firefox Fork"
    description="CryFox is a privacy-first Firefox fork that strips away telemetry, blocks trackers by default, and hardens your browser against fingerprinting."
    keywords="CryFox, Firefox fork, privacy browser, tracker blocking, fingerprint protection, secure browser"
    activePage="projects"
    ogType="article"
>
    <section class="page-hero">
        <div class="page-hero-content">
            <h1><span class="highlight">CryFox</span></h1>
            <p>A private, secure, and fast Firefox fork.</p>
            <br />
            <div class="cryfox-hero-actions">
                <a
                    href="https://cryfox.me/"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">Download Now</a
                >
                <a
                    href="https://github.com/arcbasehq/cryfoxgecko"
                    target="_blank"
                    rel="noopener"
                    class="btn-secondary">Source Code</a
                >
            </div>
        </div>
    </section>

    <section class="section content-block">
        <div class="section-container">
            <div class="about-grid">
                <div class="fade-up">
                    <div class="section-number">About</div>
                    <h2 class="section-title">Browse without being watched</h2>
                    <p class="section-desc">
                        CryFox is a privacy-first Firefox fork that strips away
                        telemetry, blocks trackers by default, and hardens your
                        browser against fingerprinting. Built for users who
                        value speed and security without sacrificing usability.
                    </p>
                    <p class="section-desc" style="margin-top: 16px;">
                        Most browsers track your every move. CryFox doesn't. We
                        removed the telemetry, disabled the data collection, and
                        added powerful privacy protections that work silently in
                        the background.
                    </p>
                </div>
                <div class="fade-up">
                    <div class="about-card">
                        <div class="about-stats">
                            <div class="stat-item">
                                <div class="stat-number">0</div>
                                <div class="stat-label">Telemetry</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">∞</div>
                                <div class="stat-label">Privacy</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">3x</div>
                                <div class="stat-label">Faster</div>
                            </div>
                            <div class="stat-item">
                                <div class="stat-number">100%</div>
                                <div class="stat-label">Open Source</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <div class="section-number fade-up">Features</div>
            <h2 class="section-title fade-up">Built for privacy</h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Every feature is designed to protect your privacy without
                compromising experience.
            </p>

            <div class="cryfox-features-grid">
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><circle cx="12" cy="12" r="10"></circle><line
                                x1="4.93"
                                y1="4.93"
                                x2="19.07"
                                y2="19.07"></line></svg
                        >
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Enhanced Privacy Protection</h3>
                        <p>
                            Strips away all telemetry and data collection. Your
                            browsing history stays on your device, not in the
                            cloud.
                        </p>
                    </div>
                </div>
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><path
                                d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
                            ></path></svg
                        >
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Tracker Blocking</h3>
                        <p>
                            Blocks known trackers by default. Built-in list
                            updates automatically to catch new trackers.
                        </p>
                    </div>
                </div>
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><rect
                                x="3"
                                y="11"
                                width="18"
                                height="11"
                                rx="2"
                                ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"
                            ></path></svg
                        >
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Fingerprint Hardening</h3>
                        <p>
                            Randomizes fingerprint signals so advertisers can't
                            build a profile on you across websites.
                        </p>
                    </div>
                </div>
                <div class="cryfox-feature fade-up">
                    <div class="cryfox-feature-icon">
                        <svg
                            viewBox="0 0 24 24"
                            width="22"
                            height="22"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            ><polygon
                                points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"
                            ></polygon></svg
                        >
                    </div>
                    <div class="cryfox-feature-text">
                        <h3>Performance Optimized</h3>
                        <p>
                            Without the tracking code, CryFox loads pages
                            faster. Expect noticeably quicker browsing.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block alt">
        <div class="section-container">
            <div class="section-number fade-up">Why</div>
            <h2 class="section-title fade-up">Why CryFox?</h2>
            <p class="section-desc fade-up" style="margin-bottom: 40px;">
                Your browser knows more about you than anything else. It
                deserves better.
            </p>

            <div class="cryfox-why-grid">
                <div class="cryfox-why-card fade-up">
                    <div class="cryfox-why-num">01</div>
                    <h3>Open Source</h3>
                    <p>
                        Every line of code is public. Audit it yourself or trust
                        the community to do it for you.
                    </p>
                </div>
                <div class="cryfox-why-card fade-up">
                    <div class="cryfox-why-num">02</div>
                    <h3>No Corporate Interests</h3>
                    <p>
                        We're not funded by advertisers. Your data has no value
                        to us because we don't monetize it.
                    </p>
                </div>
                <div class="cryfox-why-card fade-up">
                    <div class="cryfox-why-num">03</div>
                    <h3>Firefox Based</h3>
                    <p>
                        Built on Firefox for extension compatibility and web
                        standards. Your favorite addons will work.
                    </p>
                </div>
                <div class="cryfox-why-card fade-up">
                    <div class="cryfox-why-num">04</div>
                    <h3>Actively Maintained</h3>
                    <p>
                        Regular updates as privacy threats evolve. We stay ahead
                        so you can browse free.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="section content-block" style="text-align: center;">
        <div class="section-container fade-up">
            <h2 class="section-title">Take back your privacy</h2>
            <p class="section-desc" style="margin: 0 auto 24px;">
                CryFox is free and open source. Download it today and browse
                without being watched.
            </p>
            <div
                style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;"
            >
                <a
                    href="https://github.com/arcbasehq/cryfox"
                    target="_blank"
                    rel="noopener"
                    class="btn-primary">View on GitHub</a
                >
                <a href="/projects" class="btn-secondary">All Projects</a>
            </div>
        </div>
    </section>

    <script
        type="application/ld+json"
        set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            name: "CryFox",
            applicationCategory: "WebBrowser",
            operatingSystem: "Windows, macOS, Linux",
            offers: {
                "@type": "Offer",
                price: "0",
                priceCurrency: "USD",
            },
            description: "A private, secure, and fast Firefox fork.",
            featureList: [
                "Enhanced privacy protection",
                "Tracker blocking",
                "Fingerprint hardening",
                "Performance optimized",
            ],
            author: {
                "@type": "Organization",
                name: "arcbase",
            },
        })}
    />
</Layout>

<style>
    .cryfox-features-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        max-width: 900px;
        margin: 0 auto;
    }

    .cryfox-feature {
        display: flex;
        gap: 16px;
        padding: 24px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }

    .cryfox-feature-icon {
        width: 44px;
        height: 44px;
        flex-shrink: 0;
        background: var(--accent-light);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
    }

    .cryfox-feature-text h3 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 6px;
    }

    .cryfox-feature-text p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.6;
        margin: 0;
    }

    .cryfox-why-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .cryfox-why-card {
        padding: 24px 20px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        text-align: center;
    }

    .cryfox-why-num {
        font-size: 0.6875rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: 0.08em;
        margin-bottom: 12px;
    }

    .cryfox-why-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text-primary);
        margin-bottom: 8px;
    }

    .cryfox-why-card p {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.5;
        margin: 0;
    }

    @media (max-width: 768px) {
        .cryfox-features-grid {
            grid-template-columns: 1fr;
        }
        .cryfox-why-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 480px) {
        .cryfox-why-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
